@model Needis.Web.ViewModels.Admin.SeoRedirectEditViewModel
@{
    ViewData["Title"] = "Add Redirect";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Add Redirect</h4>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm" style="max-width:640px">
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="SourcePath" class="form-label fw-medium"></label>
                <input asp-for="SourcePath" class="form-control font-monospace" placeholder="/old-url" />
                <span asp-validation-for="SourcePath" class="text-danger small"></span>
                <div class="form-text">Must start with /</div>
            </div>
            <div class="mb-3">
                <label asp-for="TargetPath" class="form-label fw-medium"></label>
                <input asp-for="TargetPath" class="form-control font-monospace" placeholder="/new-url" />
                <span asp-validation-for="TargetPath" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StatusCode" class="form-label fw-medium"></label>
                <select asp-for="StatusCode" class="form-select">
                    <option value="301">301 – Permanent Redirect</option>
                    <option value="302">302 – Temporary Redirect</option>
                </select>
                <span asp-validation-for="StatusCode" class="text-danger small"></span>
            </div>
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
            </div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-floppy-fill me-2"></i>Save Redirect
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
