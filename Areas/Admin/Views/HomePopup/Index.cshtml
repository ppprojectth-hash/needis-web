@model IEnumerable<Needis.Web.Models.HomePopup>
@{
    ViewData["Title"] = "Home Popups / Announcements";

    string TruncateUrl(string? url, int max = 40)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        var display = System.Text.RegularExpressions.Regex.Replace(url.Trim(), @"^https?://(www\.)?", "");
        return display.Length > max ? display[..max] + "…" : display;
    }

    string Truncate(string? text, int max = 70)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        var t = text.Trim();
        return t.Length > max ? t[..max] + "…" : t;
    }
}

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 rounded-3 mb-4">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>@successMsg</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h5 class="fw-bold mb-0">
            <i class="bi bi-megaphone me-2" style="color:#2d4199"></i>Home Popups / Announcements
        </h5>
        <p class="text-muted small mb-0 mt-1">Manage announcement popups shown on the home page</p>
    </div>
    <a asp-action="Create" class="btn btn-sm btn-primary px-3" style="background:#2d4199;border-color:#2d4199">
        <i class="bi bi-plus-lg me-1"></i>Add Popup
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    @if (!Model.Any())
    {
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-megaphone fs-1 d-block mb-3" style="color:#c5cde8"></i>
            <p class="fw-semibold mb-1">No popups yet</p>
            <p class="small mb-3">Create your first announcement popup for the home page.</p>
            <a asp-action="Create" class="btn btn-sm btn-primary" style="background:#2d4199;border-color:#2d4199">
                <i class="bi bi-plus-lg me-1"></i>Add Popup
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 admin-table">
                <thead style="background:#f8f9fc">
                    <tr class="text-muted small fw-semibold" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.04em">
                        <th class="ps-4 py-3" style="width:104px">Preview</th>
                        <th class="py-3">Popup Info</th>
                        <th class="py-3" style="width:130px">Type</th>
                        <th class="py-3" style="width:180px">Display Period</th>
                        <th class="py-3" style="width:140px">Frequency</th>
                        <th class="py-3" style="width:100px">Status</th>
                        <th class="py-3 text-end pe-4 actions-cell">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var now = DateTime.UtcNow;
                    }
                    @foreach (var p in Model)
                    {
                        var isScheduled = p.StartDateUtc.HasValue && p.StartDateUtc > now;
                        var isExpired   = p.EndDateUtc.HasValue   && p.EndDateUtc   < now;
                        string statusBadge;
                        string statusClass;
                        if (!p.IsActive)      { statusBadge = "Inactive";  statusClass = "text-bg-secondary"; }
                        else if (isExpired)   { statusBadge = "Expired";   statusClass = "text-bg-warning"; }
                        else if (isScheduled) { statusBadge = "Scheduled"; statusClass = "text-bg-info"; }
                        else                  { statusBadge = "Active";    statusClass = "text-bg-success"; }

                        var typeLabel = string.IsNullOrWhiteSpace(p.PopupType) ? "General" : p.PopupType;

                        string displayPeriod;
                        if (p.StartDateUtc.HasValue && p.EndDateUtc.HasValue)
                            displayPeriod = $"{p.StartDateUtc.Value.ToLocalTime():dd MMM yyyy} → {p.EndDateUtc.Value.ToLocalTime():dd MMM yyyy}";
                        else if (p.StartDateUtc.HasValue)
                            displayPeriod = $"From {p.StartDateUtc.Value.ToLocalTime():dd MMM yyyy}";
                        else if (p.EndDateUtc.HasValue)
                            displayPeriod = $"Until {p.EndDateUtc.Value.ToLocalTime():dd MMM yyyy}";
                        else
                            displayPeriod = "Always";

                        string frequency = p.ShowOncePerDay     ? "Once per day"
                                          : p.ShowOncePerSession ? "Once per session"
                                          : "Every visit";

                        var buttonText = string.IsNullOrWhiteSpace(p.ButtonTextEN) ? p.ButtonTextTH : p.ButtonTextEN;
                        var descPreview = string.IsNullOrWhiteSpace(p.DescriptionEN) ? p.DescriptionTH : p.DescriptionEN;

                        <tr>
                            <td class="ps-4 py-2">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="" class="home-popup-preview" />
                                }
                                else
                                {
                                    <div class="home-popup-preview d-flex flex-column align-items-center justify-content-center text-muted">
                                        <i class="bi bi-image"></i>
                                        <span style="font-size:.65rem">No image</span>
                                    </div>
                                }
                            </td>
                            <td class="py-2">
                                <div class="popup-info-title">@p.TitleEN</div>
                                @if (!string.IsNullOrEmpty(p.TitleTH))
                                {
                                    <div class="popup-info-subtitle">@p.TitleTH</div>
                                }
                                @if (!string.IsNullOrEmpty(buttonText) || !string.IsNullOrEmpty(p.LinkUrl))
                                {
                                    <div class="popup-info-meta">
                                        @if (!string.IsNullOrEmpty(buttonText))
                                        {
                                            <div><i class="bi bi-hand-index-thumb me-1"></i>Button: @buttonText</div>
                                        }
                                        @if (!string.IsNullOrEmpty(p.LinkUrl))
                                        {
                                            <div class="text-truncate" style="max-width:320px">
                                                <i class="bi bi-link-45deg me-1"></i>Link: @TruncateUrl(p.LinkUrl)
                                            </div>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(descPreview))
                                {
                                    <div class="popup-info-meta text-truncate" style="max-width:360px">@Truncate(descPreview)</div>
                                }
                            </td>
                            <td class="py-2">
                                <span class="admin-badge admin-badge-neutral">@typeLabel</span>
                            </td>
                            <td class="py-2 small text-muted">@displayPeriod</td>
                            <td class="py-2">
                                <span class="admin-badge admin-badge-muted">@frequency</span>
                            </td>
                            <td class="py-2">
                                <span class="badge rounded-pill @statusClass">@statusBadge</span>
                            </td>
                            <td class="actions-cell pe-4">
                                <div class="admin-actions">
                                    <a asp-action="Edit" asp-route-id="@p.Id"
                                       class="admin-action-btn admin-action-btn-edit"
                                       title="Edit" aria-label="Edit popup">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleActive" asp-route-id="@p.Id" method="post"
                                          class="admin-action-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="admin-action-btn @(p.IsActive ? "admin-action-btn-success" : "admin-action-btn-secondary")"
                                                title="@(p.IsActive ? "Deactivate" : "Activate")"
                                                aria-label="@(p.IsActive ? "Deactivate popup" : "Activate popup")">
                                            <i class="bi @(p.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                                          class="admin-action-form"
                                          onsubmit="return confirm('Delete this popup? This cannot be undone.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="admin-action-btn admin-action-btn-delete"
                                                title="Delete" aria-label="Delete popup">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
