@model Needis.Web.ViewModels.Admin.MediaEditViewModel
@{
    ViewData["Title"] = $"Edit — {Model.OriginalFileName}";
    Layout = "_AdminLayout";

    bool isImage = Model.FileType == "Image";
    string FileSizeLabel(long bytes)
    {
        if (bytes < 1024)         return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0 text-truncate" style="color:#1a2b6b;max-width:600px">
        <i class="bi bi-pencil me-2"></i>Edit Metadata
    </h4>
</div>

<div class="row g-4">

    @* Left: Preview + file info *@
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            @if (isImage)
            {
                <div class="d-flex align-items-center justify-content-center p-3"
                     style="background:#f8f9fc;min-height:180px">
                    <img src="@Model.FileUrl" alt="@Model.OriginalFileName"
                         style="max-width:100%;max-height:180px;object-fit:contain" />
                </div>
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center"
                     style="background:#f8f9fc;height:120px">
                    @{
                        var icon = Model.FileType == "Pdf" ? "bi-file-earmark-pdf text-danger"
                            : "bi-file-earmark text-secondary";
                    }
                    <i class="bi @icon" style="font-size:3rem"></i>
                </div>
            }
            <div class="card-body p-3">
                <div class="small fw-semibold text-truncate mb-1" title="@Model.OriginalFileName">
                    @Model.OriginalFileName
                </div>
                <div class="small text-muted">@Model.FileType · @Model.FileExtension · @FileSizeLabel(Model.FileSize)</div>
                <div class="input-group input-group-sm mt-2">
                    <input type="text" class="form-control font-monospace" id="fileUrlInput"
                           value="@Model.FileUrl" readonly style="font-size:.7rem" />
                    <button class="btn btn-outline-secondary" id="copyUrlBtn" type="button">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* Right: Edit form *@
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()

                    <h6 class="fw-semibold border-bottom pb-2 mb-3" style="color:#2d4199">Title</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small">Title (TH)</label>
                            <input asp-for="TitleTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Title (EN)</label>
                            <input asp-for="TitleEN" class="form-control" />
                        </div>
                    </div>

                    <h6 class="fw-semibold border-bottom pb-2 mb-3" style="color:#2d4199">Alt Text</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small">Alt Text (TH)</label>
                            <input asp-for="AltTextTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Alt Text (EN)</label>
                            <input asp-for="AltTextEN" class="form-control" />
                        </div>
                    </div>

                    <h6 class="fw-semibold border-bottom pb-2 mb-3" style="color:#2d4199">Caption</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small">Caption (TH)</label>
                            <input asp-for="CaptionTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Caption (EN)</label>
                            <input asp-for="CaptionEN" class="form-control" />
                        </div>
                    </div>

                    <h6 class="fw-semibold border-bottom pb-2 mb-3" style="color:#2d4199">Description</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label small">Description (TH)</label>
                            <textarea asp-for="DescriptionTH" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Description (EN)</label>
                            <textarea asp-for="DescriptionEN" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <h6 class="fw-semibold border-bottom pb-2 mb-3" style="color:#2d4199">Visibility</h6>
                    <div class="d-flex gap-4 mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublic" class="form-check-input" role="switch" />
                            <label asp-for="IsPublic" class="form-check-label">Public</label>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" role="switch" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" style="background:#2d4199;border-color:#2d4199">
                            <i class="bi bi-floppy me-1"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('copyUrlBtn').addEventListener('click', function() {
    const input = document.getElementById('fileUrlInput');
    navigator.clipboard.writeText(input.value).then(() => {
        this.innerHTML = '<i class="bi bi-check2"></i>';
        setTimeout(() => this.innerHTML = '<i class="bi bi-clipboard"></i>', 1500);
    });
});
</script>
}
