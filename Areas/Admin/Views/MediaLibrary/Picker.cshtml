@model List<Needis.Web.Models.MediaFile>
@{
    ViewData["Title"] = "Media Picker";
    Layout = "_AdminLayout";
    var fileType  = ViewData["PickerFileType"]  as string;
    var usageType = ViewData["PickerUsageType"] as string;

    string FileSizeLabel(long bytes)
    {
        if (bytes < 1024)         return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0" style="color:#1a2b6b">
        <i class="bi bi-folder2-open me-2"></i>Media Picker
    </h4>
    <div class="text-muted small">@Model.Count file(s)</div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-images" style="font-size:3rem;opacity:.3"></i>
        <p class="mt-3">No files found.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var file in Model)
        {
            bool isImage = file.FileType == "Image";
            <div class="col-6 col-md-3 col-lg-2">
                <div class="card border-0 shadow-sm rounded-3 h-100" style="overflow:hidden">
                    <div class="d-flex align-items-center justify-content-center"
                         style="height:100px;background:#f3f5f9;overflow:hidden">
                        @if (isImage)
                        {
                            <img src="@file.FileUrl" alt="@file.OriginalFileName"
                                 style="max-height:100px;max-width:100%;object-fit:contain" />
                        }
                        else
                        {
                            <i class="bi @(file.FileType == "Pdf" ? "bi-file-earmark-pdf text-danger" : "bi-file-earmark text-secondary")"
                               style="font-size:2rem"></i>
                        }
                    </div>
                    <div class="card-body p-2">
                        <div class="small text-truncate mb-1" title="@file.OriginalFileName"
                             style="font-size:.72rem;color:#1a2b6b;font-weight:600">
                            @file.OriginalFileName
                        </div>
                        <div class="text-muted" style="font-size:.65rem">@FileSizeLabel(file.FileSize)</div>
                        <button type="button"
                                class="btn btn-xs btn-primary w-100 mt-2 copy-url-btn"
                                data-url="@file.FileUrl"
                                style="font-size:.7rem;padding:2px;background:#2d4199;border-color:#2d4199">
                            <i class="bi bi-clipboard me-1"></i>Copy URL
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
document.querySelectorAll('.copy-url-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const url = this.dataset.url;
        navigator.clipboard.writeText(url).then(() => {
            const orig = this.innerHTML;
            this.textContent = 'Copied!';
            setTimeout(() => this.innerHTML = orig, 1500);
        });
        // If opened in a parent window, post message
        if (window.opener) {
            window.opener.postMessage({ type: 'mediaPickerSelect', url: url }, '*');
            window.close();
        }
    });
});
</script>
}
