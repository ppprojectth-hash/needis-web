@model Needis.Web.Models.MediaFile
@{
    ViewData["Title"] = Model.OriginalFileName;
    Layout = "_AdminLayout";

    string FileSizeLabel(long bytes)
    {
        if (bytes < 1024)         return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }

    bool isImage = Model.FileType == "Image";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0 text-truncate" style="color:#1a2b6b;max-width:600px">
        <i class="bi @(isImage ? "bi-image" : "bi-file-earmark") me-2"></i>@Model.OriginalFileName
    </h4>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    @* Left: Preview *@
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
            @if (isImage)
            {
                <div class="d-flex align-items-center justify-content-center p-3"
                     style="background:#f8f9fc;min-height:260px">
                    <img src="@Model.FileUrl" alt="@(Model.AltTextEN ?? Model.OriginalFileName)"
                         style="max-width:100%;max-height:320px;object-fit:contain"
                         onerror="this.outerHTML='<div class=\'text-muted text-center p-5\'><i class=\'bi bi-image fs-1\'></i><p>Preview unavailable</p></div>'" />
                </div>
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center"
                     style="background:#f8f9fc;height:200px">
                    @{
                        var icon = Model.FileType == "Pdf" ? "bi-file-earmark-pdf text-danger"
                            : Model.FileType == "Document" ? "bi-file-earmark-word text-primary"
                            : "bi-file-earmark text-secondary";
                    }
                    <i class="bi @icon" style="font-size:5rem"></i>
                </div>
            }
            <div class="card-body p-3">
                <div class="input-group input-group-sm mb-2">
                    <input type="text" class="form-control font-monospace" id="fileUrlInput"
                           value="@Model.FileUrl" readonly />
                    <button class="btn btn-outline-secondary" id="copyUrlBtn" type="button">
                        <i class="bi bi-clipboard"></i> Copy URL
                    </button>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Download" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-download me-1"></i>Download
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-primary" style="background:#2d4199;border-color:#2d4199">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* Right: Info *@
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header bg-transparent border-0 pt-3 pb-1 px-4">
                <h6 class="fw-bold mb-0" style="color:#2d4199">File Information</h6>
            </div>
            <div class="card-body px-4 pb-3">
                <table class="table table-sm table-borderless small mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Original Name</td>
                        <td>@Model.OriginalFileName</td></tr>
                    <tr><td class="text-muted fw-semibold">Stored As</td>
                        <td class="font-monospace">@Model.FileName</td></tr>
                    <tr><td class="text-muted fw-semibold">File URL</td>
                        <td class="font-monospace text-break" style="font-size:.75rem">@Model.FileUrl</td></tr>
                    <tr><td class="text-muted fw-semibold">File Type</td>
                        <td><span class="badge bg-primary">@Model.FileType</span></td></tr>
                    <tr><td class="text-muted fw-semibold">Content Type</td>
                        <td>@Model.ContentType</td></tr>
                    <tr><td class="text-muted fw-semibold">Extension</td>
                        <td><code>@Model.FileExtension</code></td></tr>
                    <tr><td class="text-muted fw-semibold">File Size</td>
                        <td>@FileSizeLabel(Model.FileSize)</td></tr>
                    <tr><td class="text-muted fw-semibold">Usage Type</td>
                        <td>@(Model.UsageType ?? "—")</td></tr>
                    <tr><td class="text-muted fw-semibold">Related Module</td>
                        <td>@(Model.RelatedModule ?? "—")</td></tr>
                    <tr><td class="text-muted fw-semibold">Is Public</td>
                        <td>@(Model.IsPublic ? "✓ Yes" : "No")</td></tr>
                    <tr><td class="text-muted fw-semibold">Is Active</td>
                        <td>@(Model.IsActive ? "✓ Yes" : "No")</td></tr>
                    <tr><td class="text-muted fw-semibold">Uploaded</td>
                        <td>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            @if (!string.IsNullOrEmpty(Model.CreatedBy))
                            {
                                <span class="text-muted">by @Model.CreatedBy</span>
                            }
                        </td></tr>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <tr><td class="text-muted fw-semibold">Updated</td>
                            <td>@Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                @if (!string.IsNullOrEmpty(Model.UpdatedBy))
                                {
                                    <span class="text-muted">by @Model.UpdatedBy</span>
                                }
                            </td></tr>
                    }
                </table>
            </div>
        </div>

        @* Metadata *@
        @if (!string.IsNullOrEmpty(Model.TitleEN) || !string.IsNullOrEmpty(Model.TitleTH) ||
             !string.IsNullOrEmpty(Model.AltTextEN) || !string.IsNullOrEmpty(Model.AltTextTH))
        {
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pt-3 pb-1 px-4">
                    <h6 class="fw-bold mb-0" style="color:#2d4199">Metadata</h6>
                </div>
                <div class="card-body px-4 pb-3">
                    <table class="table table-sm table-borderless small mb-0">
                        @if (!string.IsNullOrEmpty(Model.TitleEN) || !string.IsNullOrEmpty(Model.TitleTH))
                        {
                            <tr><td class="text-muted fw-semibold" style="width:40%">Title (TH)</td>
                                <td>@(Model.TitleTH ?? "—")</td></tr>
                            <tr><td class="text-muted fw-semibold">Title (EN)</td>
                                <td>@(Model.TitleEN ?? "—")</td></tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.AltTextEN) || !string.IsNullOrEmpty(Model.AltTextTH))
                        {
                            <tr><td class="text-muted fw-semibold">Alt Text (TH)</td>
                                <td>@(Model.AltTextTH ?? "—")</td></tr>
                            <tr><td class="text-muted fw-semibold">Alt Text (EN)</td>
                                <td>@(Model.AltTextEN ?? "—")</td></tr>
                        }
                        @if (!string.IsNullOrEmpty(Model.CaptionEN) || !string.IsNullOrEmpty(Model.CaptionTH))
                        {
                            <tr><td class="text-muted fw-semibold">Caption (TH)</td>
                                <td>@(Model.CaptionTH ?? "—")</td></tr>
                            <tr><td class="text-muted fw-semibold">Caption (EN)</td>
                                <td>@(Model.CaptionEN ?? "—")</td></tr>
                        }
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
document.getElementById('copyUrlBtn').addEventListener('click', function() {
    const input = document.getElementById('fileUrlInput');
    navigator.clipboard.writeText(input.value).then(() => {
        const orig = this.innerHTML;
        this.innerHTML = '<i class="bi bi-check2"></i> Copied!';
        this.classList.add('btn-success');
        this.classList.remove('btn-outline-secondary');
        setTimeout(() => {
            this.innerHTML = orig;
            this.classList.remove('btn-success');
            this.classList.add('btn-outline-secondary');
        }, 2000);
    });
});
</script>
}
