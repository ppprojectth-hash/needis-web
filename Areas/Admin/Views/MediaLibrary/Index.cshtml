@model Needis.Web.ViewModels.Admin.MediaLibraryIndexViewModel
@{
    ViewData["Title"] = "Media Library";
    Layout = "_AdminLayout";

    string FileSizeLabel(long bytes)
    {
        if (bytes < 1024)             return $"{bytes} B";
        if (bytes < 1024 * 1024)     return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:#1a2b6b">
            <i class="bi bi-images me-2"></i>Media Library
        </h4>
        <p class="text-muted small mb-0">@Model.TotalCount files · @Model.FormatStorage() used</p>
    </div>
    <a asp-action="Upload" class="btn btn-sm btn-primary" style="background:#2d4199;border-color:#2d4199">
        <i class="bi bi-upload me-1"></i> Upload File
    </a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Summary Cards ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 text-center p-3">
            <div class="fs-4 fw-bold" style="color:#2d4199">@Model.TotalCount</div>
            <div class="text-muted small">Total Files</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 text-center p-3">
            <div class="fs-4 fw-bold text-success">@Model.ImageCount</div>
            <div class="text-muted small">Images</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 text-center p-3">
            <div class="fs-4 fw-bold text-danger">@Model.PdfCount</div>
            <div class="text-muted small">PDFs</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-3 text-center p-3">
            <div class="fs-4 fw-bold text-warning">@Model.DocumentCount</div>
            <div class="text-muted small">Documents</div>
        </div>
    </div>
</div>

@* ── Filter Form ── *@
<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-3">
                <input type="text" name="keyword" value="@Model.Keyword" class="form-control form-control-sm"
                       placeholder="Search files..." />
            </div>
            <div class="col-md-2">
                <select name="fileType" class="form-select form-select-sm">
                    <option value="">All Types</option>
                    <option value="Image"    selected="@(Model.FileType == "Image"    ? "selected" : null)">Image</option>
                    <option value="Pdf"      selected="@(Model.FileType == "Pdf"      ? "selected" : null)">PDF</option>
                    <option value="Document" selected="@(Model.FileType == "Document" ? "selected" : null)">Document</option>
                    <option value="Other"    selected="@(Model.FileType == "Other"    ? "selected" : null)">Other</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="usageType" class="form-select form-select-sm">
                    <option value="">All Usage</option>
                    @foreach (var u in new[]{"General","Logo","Banner","Product","ProductBrochure","Category","About","Service","Activity","SEO"})
                    {
                        <option value="@u" selected="@(Model.UsageType == u ? "selected" : null)">@u</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="relatedModule" class="form-select form-select-sm">
                    <option value="">All Modules</option>
                    @foreach (var m in new[]{"General","SiteSetting","HomeBanner","Product","ProductCategory","About","Service","Activity","SEO"})
                    {
                        <option value="@m" selected="@(Model.RelatedModule == m ? "selected" : null)">@m</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary" style="background:#2d4199;border-color:#2d4199">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@* ── File Grid ── *@
@if (!Model.MediaFiles.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-folder2-open" style="font-size:3rem;opacity:.3"></i>
        <p class="mt-3">No files found. <a asp-action="Upload">Upload your first file →</a></p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var file in Model.MediaFiles)
        {
            var isImage = file.FileType == "Image";
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 h-100" style="overflow:hidden">
                    @* Preview *@
                    <div class="media-thumb d-flex align-items-center justify-content-center"
                         style="height:140px;background:#f3f5f9;overflow:hidden">
                        @if (isImage)
                        {
                            <img src="@file.FileUrl" alt="@(file.AltTextEN ?? file.OriginalFileName)"
                                 style="max-height:140px;max-width:100%;object-fit:contain"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <div style="display:none;align-items:center;justify-content:center;height:100%;width:100%">
                                <i class="bi bi-image text-muted" style="font-size:2.5rem"></i>
                            </div>
                        }
                        else
                        {
                            var icon = file.FileType == "Pdf" ? "bi-file-earmark-pdf text-danger"
                                : file.FileType == "Document" ? "bi-file-earmark-word text-primary"
                                : "bi-file-earmark text-secondary";
                            <i class="bi @icon" style="font-size:3rem"></i>
                        }
                    </div>
                    <div class="card-body p-2">
                        <div class="fw-semibold text-truncate small mb-1" title="@file.OriginalFileName"
                             style="color:#1a2b6b;font-size:.78rem">
                            @file.OriginalFileName
                        </div>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <span class="badge @(isImage ? "bg-success" : file.FileType == "Pdf" ? "bg-danger" : "bg-secondary")"
                                  style="font-size:.6rem">@file.FileType</span>
                            <span class="badge bg-light text-dark border" style="font-size:.6rem">
                                @FileSizeLabel(file.FileSize)
                            </span>
                            @if (!string.IsNullOrEmpty(file.UsageType))
                            {
                                <span class="badge bg-light text-dark border" style="font-size:.6rem">@file.UsageType</span>
                            }
                        </div>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="Details" asp-route-id="@file.Id"
                               class="btn btn-xs btn-outline-primary" style="font-size:.7rem;padding:1px 6px">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@file.Id"
                               class="btn btn-xs btn-outline-secondary" style="font-size:.7rem;padding:1px 6px">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button"
                                    class="btn btn-xs btn-outline-secondary copy-url-btn"
                                    data-url="@file.FileUrl"
                                    style="font-size:.7rem;padding:1px 6px"
                                    title="Copy URL">
                                <i class="bi bi-clipboard"></i>
                            </button>
                            <form asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@file.Id" />
                                <button type="submit"
                                        class="btn btn-xs btn-outline-danger"
                                        style="font-size:.7rem;padding:1px 6px"
                                        onclick="return confirm('Delete this file from Media Library?')">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.MediaFiles.Count >= 300)
    {
        <div class="alert alert-info mt-4 mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Showing the latest 300 files. Use filters to narrow your search.
        </div>
    }
}

@section Scripts {
<script>
document.querySelectorAll('.copy-url-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const url = this.dataset.url;
        navigator.clipboard.writeText(url).then(() => {
            const orig = this.innerHTML;
            this.innerHTML = '<i class="bi bi-check2"></i>';
            this.classList.replace('btn-outline-secondary', 'btn-success');
            setTimeout(() => {
                this.innerHTML = orig;
                this.classList.replace('btn-success', 'btn-outline-secondary');
            }, 1500);
        });
    });
});
</script>
}
