@model Needis.Web.ViewModels.Admin.ActivityPageViewModel
@{
    ViewData["Title"] = "Create Activity Page Setting";
}

<div class="card border-0 shadow-sm rounded-3 mx-auto" style="max-width:760px">
    <div class="card-body p-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PageKey" class="form-label fw-medium">Page Key <span class="text-danger">*</span></label>
                    <input asp-for="PageKey" class="form-control" placeholder="e.g. activity_main" />
                    <span asp-validation-for="PageKey" class="text-danger small"></span>
                    <div class="form-text">Unique key. Use lowercase_underscore format.</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="DisplayOrder" class="form-label fw-medium">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="TitleEN" class="form-label fw-medium">Title EN <span class="text-danger">*</span></label>
                    <input asp-for="TitleEN" class="form-control" />
                    <span asp-validation-for="TitleEN" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TitleTH" class="form-label fw-medium">Title TH</label>
                    <input asp-for="TitleTH" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SubtitleEN" class="form-label fw-medium">Subtitle EN</label>
                    <input asp-for="SubtitleEN" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SubtitleTH" class="form-label fw-medium">Subtitle TH</label>
                    <input asp-for="SubtitleTH" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="BreadcrumbTextEN" class="form-label fw-medium">Breadcrumb EN</label>
                    <input asp-for="BreadcrumbTextEN" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="BreadcrumbTextTH" class="form-label fw-medium">Breadcrumb TH</label>
                    <input asp-for="BreadcrumbTextTH" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="DescriptionEN" class="form-label fw-medium">Description EN</label>
                    <textarea asp-for="DescriptionEN" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="DescriptionTH" class="form-label fw-medium">Description TH</label>
                    <textarea asp-for="DescriptionTH" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="BackgroundImageFile" class="form-label fw-medium">Background Image</label>
                    <input asp-for="BackgroundImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,.svg" />
                    <span asp-validation-for="BackgroundImageFile" class="text-danger small"></span>
                    <div class="form-text">Max 3 MB. jpg/jpeg/png/webp/svg accepted.</div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
