@model Needis.Web.ViewModels.Admin.AdminUserChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Change Password</h4>
        <p class="text-muted small mb-0">User: <strong>@Model.Username</strong></p>
    </div>
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0"><i class="bi bi-lock me-2 text-primary"></i>Set New Password</h6>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Username" />

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-medium"></label>
                        <input asp-for="NewPassword" class="form-control" type="password"
                               autocomplete="new-password" placeholder="Minimum 8 characters" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               autocomplete="new-password" placeholder="Repeat new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-key-fill me-2"></i>Change Password
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
