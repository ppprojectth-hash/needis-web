@model Needis.Web.ViewModels.Admin.AdminUserEditViewModel
@{
    ViewData["Title"] = "Edit Admin User";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var currentUserId = int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var uid) ? uid : 0;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Edit Admin User</h4>
        <p class="text-muted small mb-0">@Model.Username</p>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row g-4">

        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-person me-2 text-primary"></i>Account Info</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-medium"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-1">
                        <label asp-for="DisplayName" class="form-label fw-medium"></label>
                        <input asp-for="DisplayName" class="form-control" placeholder="Full name for display" />
                        <span asp-validation-for="DisplayName" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-body d-flex align-items-center justify-content-between gap-2 py-3">
                    <div>
                        <div class="fw-medium">Password</div>
                        <div class="text-muted small">Use "Change Password" to update the password.</div>
                    </div>
                    <a asp-action="ChangePassword" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning flex-shrink-0">
                        <i class="bi bi-key me-1"></i>Change Password
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h6 class="fw-semibold mb-0"><i class="bi bi-shield me-2 text-primary"></i>Role & Status</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="AdminRoleId" class="form-label fw-medium">Role</label>
                        <select asp-for="AdminRoleId" asp-items="ViewBag.AdminRoles" class="form-select">
                            <option value="">— Select Role —</option>
                        </select>
                        <span asp-validation-for="AdminRoleId" class="text-danger small"></span>
                    </div>
                    <div>
                        <div class="form-check form-switch">
                            @if (Model.Id == currentUserId)
                            {
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" disabled />
                                <input type="hidden" name="IsActive" value="true" />
                            }
                            else
                            {
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            }
                            <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                        </div>
                        @if (Model.Id == currentUserId)
                        {
                            <div class="form-text text-warning">
                                <i class="bi bi-info-circle me-1"></i>You cannot deactivate your own account.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-floppy-fill me-2"></i>Save Changes
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
