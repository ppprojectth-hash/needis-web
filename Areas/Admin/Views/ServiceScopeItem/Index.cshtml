@model List<Needis.Web.Models.ServiceScopeItem>
@{
    var detailSec = ViewBag.DetailSection as Needis.Web.Models.ServiceDetailSection;
    var svc = detailSec?.Service;
    ViewData["Title"] = $"Scope Items — {detailSec?.SectionTitleEN ?? "Section"}";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Service" asp-action="Index">Services</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="ServiceDetailSection" asp-action="Index" asp-route-serviceId="@svc?.Id">
                @(svc?.ServiceNameEN ?? "Service")
            </a>
        </li>
        <li class="breadcrumb-item active">@(detailSec?.SectionTitleEN ?? "Scope Items")</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h6 class="text-muted mb-0">Scope items in <strong>@(detailSec?.SectionTitleEN ?? "—")</strong></h6>
    <a asp-action="Create" asp-route-sectionId="@detailSec?.Id" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Item
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3 text-center" style="width:50px">Order</th>
                    <th>Title EN</th>
                    <th>Title TH</th>
                    <th>Icon</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 text-center">@item.DisplayOrder</td>
                        <td>@item.ItemTitleEN</td>
                        <td class="text-muted small">@item.ItemTitleTH</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.IconUrl))
                            {
                                <i class="@item.IconUrl"></i>
                                <span class="text-muted small ms-1">@item.IconUrl</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end pe-3 text-nowrap">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this scope item?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No scope items found. Add the first one.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
