@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
    var role     = User.FindFirst(ClaimTypes.Role)?.Value ?? "-";

    string QuotationBadge(string status) => status switch
    {
        "New"       => "bg-primary",
        "Contacted" => "bg-info text-dark",
        "Quoted"    => "bg-warning text-dark",
        "Closed"    => "bg-success",
        "Cancelled" => "bg-secondary",
        _           => "bg-light text-dark",
    };

    // Pre-compute bar chart scales
    int dailyMax   = Model.DailyUsage.Any()  ? Model.DailyUsage.Max(d => d.Count)  : 1;
    int topPageMax = Model.TopPages.Any()     ? Model.TopPages.Max(p => p.Count)    : 1;
    if (dailyMax   < 1) dailyMax   = 1;
    if (topPageMax < 1) topPageMax = 1;

    var utcToday = DateTime.UtcNow.Date;
}

<style>
    .stat-card { border: none; border-radius: 12px; box-shadow: 0 1px 4px rgba(0,0,0,.07); transition: box-shadow .15s; }
    .stat-card:hover { box-shadow: 0 4px 16px rgba(45,65,153,.12); }
    .stat-icon { width: 46px; height: 46px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.15rem; }
    .stat-number { font-size: 1.7rem; font-weight: 700; line-height: 1; color: #1a2360; }
    .stat-label { font-size: .78rem; color: #6b7280; font-weight: 500; margin-top: .15rem; }
    .stat-sub { font-size: .72rem; color: #9ca3af; margin-top: .1rem; }
    .section-title { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #6b7280; margin-bottom: .75rem; }
    .dash-table th { font-size: .73rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: #9ca3af; border-bottom-width: 1px; }
    .dash-table td { font-size: .84rem; vertical-align: middle; }
    .bar-wrap { background: #f0f3ff; border-radius: 6px; height: 8px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 6px; }
    .quick-btn { border-radius: 10px; padding: .6rem 1rem; font-size: .84rem; font-weight: 500; transition: transform .1s; }
    .quick-btn:hover { transform: translateY(-1px); }
</style>

@* ── Page Header ─────────────────────────────────────────────────────── *@
<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h5 class="fw-bold mb-0">Welcome back, @fullName</h5>
        <p class="text-muted small mb-0 mt-1">
            <i class="bi bi-shield-check me-1"></i>@role &nbsp;&middot;&nbsp;
            <i class="bi bi-circle-fill text-success me-1" style="font-size:.5rem;vertical-align:middle"></i>
            System Online &nbsp;&middot;&nbsp; Overview of content, requests, messages, and usage.
        </p>
    </div>
    <div class="text-muted small text-end">
        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("ddd, dd MMM yyyy")
    </div>
</div>

@* ── Summary Cards Row 1 ────────────────────────────────────────────── *@
<div class="row g-3 mb-3">

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="QuotationRequest" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#fff3cd">
                    <i class="bi bi-file-earmark-text" style="color:#d97706"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.NewQuotationRequests</div>
                    <div class="stat-label">New Quotations</div>
                    <div class="stat-sub">@Model.TotalQuotationRequests total</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#e8edff">
                    <i class="bi bi-box-seam" style="color:#2d4199"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.TotalProducts</div>
                    <div class="stat-label">Total Products</div>
                    <div class="stat-sub">@Model.ActiveProducts active &middot; @Model.TotalCategories categories</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="Service" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#dcfce7">
                    <i class="bi bi-tools" style="color:#16a34a"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.ActiveServices</div>
                    <div class="stat-label">Active Services</div>
                    <div class="stat-sub">@Model.TotalServices total</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="Activity" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#f0e6ff">
                    <i class="bi bi-newspaper" style="color:#7c3aed"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.PublishedActivities</div>
                    <div class="stat-label">Published Activities</div>
                    <div class="stat-sub">@Model.TotalActivities total</div>
                </div>
            </div>
        </a>
    </div>

</div>

@* ── Summary Cards Row 2 ────────────────────────────────────────────── *@
<div class="row g-3 mb-4">

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Index" asp-route-status="New"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#fce7f3">
                    <i class="bi bi-chat-left-dots" style="color:#db2777"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.NewContactMessages</div>
                    <div class="stat-label">New Messages</div>
                    <div class="stat-sub">@Model.TotalContactMessages total</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="UsageStatistic" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#e0f2fe">
                    <i class="bi bi-activity" style="color:#0284c7"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.TodayUsageCount</div>
                    <div class="stat-label">Today's Visits</div>
                    <div class="stat-sub">@Model.FailedUsageCount failed (7 days)</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="EmailLog" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#fee2e2">
                    <i class="bi bi-envelope-exclamation" style="color:#dc2626"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.EmailFailedCount</div>
                    <div class="stat-label">Email Failed</div>
                    <div class="stat-sub">@Model.EmailSkippedCount skipped (7 days)</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-sm-4 col-lg-3">
        <a asp-area="Admin" asp-controller="EmailLog" asp-action="Index"
           class="card stat-card text-decoration-none d-block h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon" style="background:#d1fae5">
                    <i class="bi bi-envelope-check" style="color:#059669"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="stat-number">@Model.EmailSuccessCount</div>
                    <div class="stat-label">Email Sent OK</div>
                    <div class="stat-sub">Last 7 days</div>
                </div>
            </div>
        </a>
    </div>

</div>

@* ── Latest Quotations + Latest Messages ─────────────────────────────── *@
<div class="row g-3 mb-3">

    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-3 h-100">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="section-title mb-0">
                        <i class="bi bi-file-earmark-text me-1"></i>Latest Quotation Requests
                    </div>
                    <a asp-area="Admin" asp-controller="QuotationRequest" asp-action="Index"
                       class="btn btn-sm btn-outline-secondary" style="font-size:.75rem">View All</a>
                </div>
                @if (!Model.LatestQuotationRequests.Any())
                {
                    <p class="text-muted small text-center py-4 mb-0">No quotation requests yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table dash-table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Request No</th>
                                    <th>Customer</th>
                                    <th class="d-none d-md-table-cell">Company</th>
                                    <th class="d-none d-sm-table-cell">Type</th>
                                    <th>Status</th>
                                    <th class="d-none d-md-table-cell">Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var q in Model.LatestQuotationRequests)
                                {
                                    <tr>
                                        <td class="fw-semibold" style="white-space:nowrap">@q.RequestNo</td>
                                        <td class="text-truncate" style="max-width:120px">@(q.CustomerName ?? "—")</td>
                                        <td class="d-none d-md-table-cell text-truncate" style="max-width:110px">@(q.CompanyName ?? "—")</td>
                                        <td class="d-none d-sm-table-cell">
                                            <span class="badge bg-light text-dark border">@(q.RequestType ?? "—")</span>
                                        </td>
                                        <td>
                                            <span class="badge @QuotationBadge(q.Status)">@q.Status</span>
                                        </td>
                                        <td class="d-none d-md-table-cell text-muted" style="white-space:nowrap;font-size:.78rem">
                                            @q.CreatedAt.ToLocalTime().ToString("dd MMM yy")
                                        </td>
                                        <td>
                                            <a asp-area="Admin" asp-controller="QuotationRequest"
                                               asp-action="Detail" asp-route-id="@q.Id"
                                               class="btn btn-sm btn-outline-primary py-0" style="font-size:.73rem">View</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 h-100">
            <div class="card-body p-3">
                <div class="section-title">
                    <i class="bi bi-chat-left-dots me-1"></i>Latest Messages
                </div>
                @if (!Model.LatestContactMessages.Any())
                {
                    <p class="text-muted small text-center py-4 mb-0">No messages yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var m in Model.LatestContactMessages)
                        {
                            <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Detail"
                               asp-route-id="@m.Id"
                               class="d-flex align-items-start gap-2 p-2 rounded-2 text-decoration-none"
                               style="background:#f8f9fb">
                                <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width:32px;height:32px;background:#e8edff;font-size:.75rem;color:#2d4199">
                                    @(m.FullName?.Length > 0 ? m.FullName[0].ToString().ToUpper() : "?")
                                </div>
                                <div class="overflow-hidden flex-grow-1">
                                    <div class="fw-semibold text-truncate text-dark" style="font-size:.83rem">@(m.FullName ?? "—")</div>
                                    <div class="text-muted text-truncate" style="font-size:.75rem">@(m.Subject ?? "—")</div>
                                    <div class="text-muted" style="font-size:.7rem">
                                        @m.CreatedAt.ToLocalTime().ToString("dd MMM yy HH:mm")
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@* ── Top Pages + Daily Usage ──────────────────────────────────────────── *@
<div class="row g-3 mb-3">

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm rounded-3 h-100">
            <div class="card-body p-3">
                <div class="section-title">
                    <i class="bi bi-bar-chart-line me-1"></i>Top Pages (Last 7 Days)
                </div>
                @if (!Model.TopPages.Any())
                {
                    <p class="text-muted small text-center py-4 mb-0">No usage data yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var pg in Model.TopPages)
                        {
                            <div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-truncate me-2" title="@pg.Url" style="font-size:.8rem;max-width:75%">
                                        @(pg.PageName ?? pg.Url ?? "—")
                                    </span>
                                    <span class="fw-semibold text-muted" style="font-size:.78rem;white-space:nowrap">
                                        @pg.Count.ToString("N0")
                                    </span>
                                </div>
                                <div class="bar-wrap">
                                    <div class="bar-fill"
                                         style="width:@((int)Math.Round((double)pg.Count / topPageMax * 100))%;background:#2d4199"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm rounded-3 h-100">
            <div class="card-body p-3">
                <div class="section-title">
                    <i class="bi bi-calendar-week me-1"></i>Daily Visits (Last 7 Days)
                </div>
                @if (!Model.DailyUsage.Any())
                {
                    <p class="text-muted small text-center py-4 mb-0">No usage data yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var day in Model.DailyUsage)
                        {
                            <div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span style="font-size:.8rem;font-weight:@(day.Date.Date == utcToday ? "700" : "400")">
                                        @day.Date.ToString("ddd, dd MMM")
                                        @if (day.Date.Date == utcToday)
                                        {
                                            <span class="badge bg-primary ms-1" style="font-size:.65rem;vertical-align:middle">Today</span>
                                        }
                                    </span>
                                    <span class="fw-semibold text-muted" style="font-size:.78rem">
                                        @day.Count.ToString("N0")
                                    </span>
                                </div>
                                <div class="bar-wrap">
                                    <div class="bar-fill"
                                         style="width:@((int)Math.Round((double)day.Count / dailyMax * 100))%;background:@(day.Date.Date == utcToday ? "#2d4199" : "#93a8e8")"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@* ── Top Products ─────────────────────────────────────────────────────── *@
@if (Model.TopProducts.Any())
{
    <div class="card border-0 shadow-sm rounded-3 mb-3">
        <div class="card-body p-3">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="section-title mb-0">
                    <i class="bi bi-eye me-1"></i>Top Viewed Products (Last 7 Days)
                </div>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                   class="btn btn-sm btn-outline-secondary" style="font-size:.75rem">All Products</a>
            </div>
            <div class="table-responsive">
                <table class="table dash-table table-hover mb-0">
                    <thead>
                        <tr>
                            <th width="36">#</th>
                            <th>Product</th>
                            <th class="text-end" width="80">Views</th>
                            <th width="60"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int pRank = 1; }
                        @foreach (var p in Model.TopProducts)
                        {
                            <tr>
                                <td class="text-muted" style="font-size:.78rem">@pRank</td>
                                <td>
                                    <div class="fw-semibold" style="font-size:.84rem">@(p.ProductNameEN ?? p.Slug ?? "—")</div>
                                    @if (!string.IsNullOrEmpty(p.ProductNameTH))
                                    {
                                        <div class="text-muted" style="font-size:.75rem">@p.ProductNameTH</div>
                                    }
                                </td>
                                <td class="text-end fw-semibold">@p.ViewCount.ToString("N0")</td>
                                <td>
                                    @if (p.ProductId > 0)
                                    {
                                        <a asp-area="Admin" asp-controller="Product"
                                           asp-action="Edit" asp-route-id="@p.ProductId"
                                           class="btn btn-sm btn-outline-primary py-0" style="font-size:.73rem">Edit</a>
                                    }
                                </td>
                            </tr>
                            pRank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ── Quick Actions ────────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3">
        <div class="section-title"><i class="bi bi-lightning-charge me-1"></i>Quick Actions</div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="btn btn-outline-primary quick-btn">
                <i class="bi bi-box-seam me-1"></i>Manage Products
            </a>
            <a asp-area="Admin" asp-controller="Service" asp-action="Index"
               class="btn btn-outline-primary quick-btn">
                <i class="bi bi-tools me-1"></i>Manage Services
            </a>
            <a asp-area="Admin" asp-controller="Activity" asp-action="Index"
               class="btn btn-outline-primary quick-btn">
                <i class="bi bi-newspaper me-1"></i>Manage Activities
            </a>
            <a asp-area="Admin" asp-controller="AboutSection" asp-action="Index"
               class="btn btn-outline-primary quick-btn">
                <i class="bi bi-info-circle me-1"></i>Manage About Us
            </a>
            <a asp-area="Admin" asp-controller="QuotationRequest" asp-action="Index"
               class="btn btn-outline-warning quick-btn">
                <i class="bi bi-file-earmark-text me-1"></i>View Quotation Requests
            </a>
            <a asp-area="Admin" asp-controller="UsageStatistic" asp-action="Index"
               class="btn btn-outline-secondary quick-btn">
                <i class="bi bi-bar-chart me-1"></i>View Usage Statistics
            </a>
        </div>
    </div>
</div>
