@model Needis.Web.ViewModels.Admin.ContactMessageIndexViewModel
@{
    ViewData["Title"] = "Contact Messages";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Contact Messages</h4>
        <p class="text-muted small mb-0">Manage public contact form submissions</p>
    </div>
    <a asp-action="ExportCsv"
       asp-route-dateFrom="@Model.DateFrom.ToString("yyyy-MM-dd")"
       asp-route-dateTo="@Model.DateTo.ToString("yyyy-MM-dd")"
       asp-route-status="@Model.Status"
       asp-route-keyword="@Model.Keyword"
       class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-download me-1"></i>Export CSV
    </a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Summary Cards *@
<div class="row g-3 mb-4">
    @{
        (string Label, int Count, string Bg, string IconColor, string StatusVal)[] cards =
        [
            ("New",     Model.NewCount,     "#dbeafe", "#1d4ed8", "New"),
            ("Read",    Model.ReadCount,    "#e0f2fe", "#0284c7", "Read"),
            ("Replied", Model.RepliedCount, "#dcfce7", "#16a34a", "Replied"),
            ("Closed",  Model.ClosedCount,  "#f3f4f6", "#6b7280", "Closed"),
            ("Spam",    Model.SpamCount,    "#fee2e2", "#dc2626", "Spam"),
            ("Total",   Model.TotalCount,   "#ede9fe", "#7c3aed", ""),
        ];
    }
    @foreach (var (label, count, bg, iconColor, statusVal) in cards)
    {
        var isActive = Model.Status == (string.IsNullOrEmpty(statusVal) ? Model.Status : statusVal);
        <div class="col-6 col-sm-4 col-lg-2">
            <a asp-action="Index"
               asp-route-dateFrom="@Model.DateFrom.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@Model.DateTo.ToString("yyyy-MM-dd")"
               asp-route-status="@(string.IsNullOrEmpty(statusVal) ? "" : statusVal)"
               asp-route-keyword="@Model.Keyword"
               class="card text-decoration-none d-block h-100 @(isActive && !string.IsNullOrEmpty(statusVal) ? "border-primary" : "border-0 shadow-sm")">
                <div class="card-body p-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center mb-2"
                         style="width:36px;height:36px;background:@bg">
                        <i class="bi bi-chat-left-dots" style="color:@iconColor;font-size:1rem"></i>
                    </div>
                    <div class="fw-bold fs-5">@count</div>
                    <div class="small text-muted">@label</div>
                </div>
            </a>
        </div>
    }
</div>

@* Filter *@
<div class="card shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-medium mb-1">Date From</label>
                <input name="dateFrom" type="date" class="form-control form-control-sm"
                       value="@Model.DateFrom.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-medium mb-1">Date To</label>
                <input name="dateTo" type="date" class="form-control form-control-sm"
                       value="@Model.DateTo.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-medium mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="New"     selected="@(Model.Status == "New"     ? "selected" : null)">New</option>
                    <option value="Read"    selected="@(Model.Status == "Read"    ? "selected" : null)">Read</option>
                    <option value="Replied" selected="@(Model.Status == "Replied" ? "selected" : null)">Replied</option>
                    <option value="Closed"  selected="@(Model.Status == "Closed"  ? "selected" : null)">Closed</option>
                    <option value="Spam"    selected="@(Model.Status == "Spam"    ? "selected" : null)">Spam</option>
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-medium mb-1">Assigned To</label>
                <input name="assignedTo" class="form-control form-control-sm" value="@Model.AssignedTo" placeholder="Username..." />
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label small fw-medium mb-1">Keyword</label>
                <input name="keyword" class="form-control form-control-sm" value="@Model.Keyword"
                       placeholder="Name, email, subject, message..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:140px">Received</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th class="d-none d-md-table-cell">Phone</th>
                    <th>Subject</th>
                    <th class="text-center">Status</th>
                    <th class="d-none d-lg-table-cell">Assigned</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Messages)
                {
                    <tr class="@(item.Status == "New" ? "table-primary" : "")">
                        <td class="small text-muted">
                            @item.CreatedAt.ToLocalTime().ToString("dd MMM yy")
                            <div class="text-nowrap">@item.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                        </td>
                        <td class="fw-medium">@(item.FullName ?? "—")</td>
                        <td class="small">
                            <a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a>
                        </td>
                        <td class="small text-muted d-none d-md-table-cell">@(item.Phone ?? "—")</td>
                        <td class="text-truncate" style="max-width:200px">@(item.Subject ?? "—")</td>
                        <td class="text-center">
                            @{
                                var (badgeBg, badgeText) = (item.Status ?? "New") switch {
                                    "New"     => ("bg-primary",   "text-white"),
                                    "Read"    => ("bg-info",      "text-white"),
                                    "Replied" => ("bg-success",   "text-white"),
                                    "Closed"  => ("bg-secondary", "text-white"),
                                    "Spam"    => ("bg-danger",    "text-white"),
                                    _         => ("bg-primary",   "text-white"),
                                };
                            }
                            <span class="badge @badgeBg @badgeText">@(item.Status ?? "New")</span>
                        </td>
                        <td class="small text-muted d-none d-lg-table-cell">@(item.AssignedTo ?? "—")</td>
                        <td class="actions-cell">
                            <div class="admin-actions">
                                <a asp-action="Detail" asp-route-id="@item.Id"
                                   class="admin-action-btn admin-action-btn-view"
                                   title="View Message" aria-label="View message">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Messages.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            No messages found for the selected filters.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Messages.Count == 300)
    {
        <div class="card-footer bg-warning-subtle text-warning-emphasis small py-2 text-center">
            Showing first 300 results. Narrow your filters to see more.
        </div>
    }
</div>
