@using Needis.Web.Models
@model List<EmailSendLog>
@{
    ViewData["Title"] = "Email Logs";

    string StatusBadge(string? s) => s switch
    {
        "Success" => "bg-success",
        "Failed"  => "bg-danger",
        "Skipped" => "bg-secondary",
        _         => "bg-light text-dark",
    };
}

@* ── Filter Form ─────────────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-3">
        <form method="get" asp-area="Admin" asp-controller="EmailLog" asp-action="Index"
              class="row g-2 align-items-end">
            <div class="col-sm-6 col-lg-2">
                <label class="form-label small fw-semibold text-muted mb-1">Date From</label>
                <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-6 col-lg-2">
                <label class="form-label small fw-semibold text-muted mb-1">Date To</label>
                <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-6 col-lg-2">
                <label class="form-label small fw-semibold text-muted mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="Success"  selected="@(ViewBag.Status == "Success"  ? "selected" : null)">Success</option>
                    <option value="Failed"   selected="@(ViewBag.Status == "Failed"   ? "selected" : null)">Failed</option>
                    <option value="Skipped"  selected="@(ViewBag.Status == "Skipped"  ? "selected" : null)">Skipped</option>
                </select>
            </div>
            <div class="col-sm-6 col-lg-4">
                <label class="form-label small fw-semibold text-muted mb-1">Keyword</label>
                <input type="text" name="keyword" value="@ViewBag.Keyword"
                       class="form-control form-control-sm"
                       placeholder="Email, subject, type, error..." />
            </div>
            <div class="col-lg-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-area="Admin" asp-controller="EmailLog" asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

@* ── Summary ──────────────────────────────────────────────────────────────── *@
<div class="d-flex align-items-center justify-content-between mb-3">
    <span class="text-muted small">
        Showing <strong>@Model.Count</strong> log@(Model.Count == 1 ? "" : "s")
        (latest 200 max)
    </span>
    <div class="d-flex gap-2">
        @{ var successCnt = Model.Count(l => l.Status == "Success"); }
        @{ var failedCnt  = Model.Count(l => l.Status == "Failed");  }
        @{ var skippedCnt = Model.Count(l => l.Status == "Skipped"); }
        @if (successCnt > 0) { <span class="badge bg-success">Success: @successCnt</span> }
        @if (failedCnt  > 0) { <span class="badge bg-danger">Failed: @failedCnt</span>   }
        @if (skippedCnt > 0) { <span class="badge bg-secondary">Skipped: @skippedCnt</span> }
    </div>
</div>

@* ── Table ────────────────────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle" style="font-size:.85rem">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:140px">Date / Time</th>
                    <th style="width:220px">Email Type</th>
                    <th style="width:220px">To Email</th>
                    <th>Subject</th>
                    <th style="width:150px">Reference</th>
                    <th class="text-center" style="width:90px">Status</th>
                    <th>Error</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-envelope fs-2 d-block mb-2 text-secondary"></i>
                            No email logs found.
                        </td>
                    </tr>
                }
                @foreach (var log in Model)
                {
                    <tr class="@(log.Status == "Failed" ? "table-danger" : "")">
                        <td class="ps-3">
                            <div>@log.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                            <div class="text-muted" style="font-size:.75rem">@log.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                        </td>
                        <td>
                            <code class="small">@(log.EmailType ?? "—")</code>
                        </td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width:210px" title="@log.ToEmail">
                                @(log.ToEmail ?? "—")
                            </span>
                        </td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width:280px" title="@log.Subject">
                                @(log.Subject ?? "—")
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.ReferenceType))
                            {
                                <span class="badge bg-light text-dark border small">@log.ReferenceType</span>
                                if (log.ReferenceId.HasValue)
                                {
                                    <span class="text-muted ms-1 small">#@log.ReferenceId</span>
                                }
                            }
                            else
                            {
                                @:—
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge @StatusBadge(log.Status)">@(log.Status ?? "—")</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.ErrorMessage))
                            {
                                <span class="text-danger small text-truncate d-inline-block"
                                      style="max-width:200px" title="@log.ErrorMessage">
                                    @log.ErrorMessage
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
