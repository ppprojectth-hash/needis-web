@model Needis.Web.ViewModels.Admin.AboutStatCardViewModel
@{
    ViewData["Title"] = "Edit Stat Card";
    var validTypes = ViewBag.ValidSourceTypes as string[] ?? Array.Empty<string>();
}

<div class="card border-0 shadow-sm rounded-3 mx-auto" style="max-width:680px">
    <div class="card-body p-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="StatKey" class="form-label fw-medium">Stat Key <span class="text-danger">*</span></label>
                    <input asp-for="StatKey" class="form-control" />
                    <span asp-validation-for="StatKey" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SourceType" class="form-label fw-medium">Source Type <span class="text-danger">*</span></label>
                    <select asp-for="SourceType" class="form-select">
                        @foreach (var t in validTypes)
                        {
                            <option value="@t" selected="@(Model.SourceType == t ? "selected" : null)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="LabelEN" class="form-label fw-medium">Label EN <span class="text-danger">*</span></label>
                    <input asp-for="LabelEN" class="form-control" />
                    <span asp-validation-for="LabelEN" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LabelTH" class="form-label fw-medium">Label TH</label>
                    <input asp-for="LabelTH" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DescriptionEN" class="form-label fw-medium">Description EN</label>
                    <input asp-for="DescriptionEN" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DescriptionTH" class="form-label fw-medium">Description TH</label>
                    <input asp-for="DescriptionTH" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ManualValue" class="form-label fw-medium">Manual Value</label>
                    <input asp-for="ManualValue" type="number" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Prefix" class="form-label fw-medium">Prefix</label>
                    <input asp-for="Prefix" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Suffix" class="form-label fw-medium">Suffix</label>
                    <input asp-for="Suffix" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="IconUrl" class="form-label fw-medium">Icon</label>
                    <input asp-for="IconUrl" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="CardStyle" class="form-label fw-medium">Card Style</label>
                    <input asp-for="CardStyle" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="DisplayOrder" class="form-label fw-medium">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
