@model List<Needis.Web.Models.ServicePage>
@{
    ViewData["Title"] = "Service Page Settings";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h6 class="text-muted mb-0">Manage hero/header settings for the Services page</h6>
    <a asp-action="Create" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Page Setting
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Page Key</th>
                    <th>Title EN</th>
                    <th>Subtitle EN</th>
                    <th class="text-center">Order</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pg in Model)
                {
                    <tr>
                        <td class="ps-3"><code>@pg.PageKey</code></td>
                        <td>@pg.TitleEN</td>
                        <td class="text-muted small">@(pg.SubtitleEN?.Length > 60 ? pg.SubtitleEN[..60] + "…" : pg.SubtitleEN)</td>
                        <td class="text-center">@pg.DisplayOrder</td>
                        <td class="text-center">
                            @if (pg.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="actions-cell pe-3">
                            <div class="admin-actions">
                                <a asp-action="Edit" asp-route-id="@pg.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit page setting">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@pg.Id" method="post"
                                      class="admin-action-form"
                                      onsubmit="return confirm('Delete this page setting?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="admin-action-btn admin-action-btn-delete"
                                            title="Delete" aria-label="Delete page setting">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No page settings found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
