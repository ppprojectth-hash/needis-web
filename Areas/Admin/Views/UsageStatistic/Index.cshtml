@model Needis.Web.ViewModels.Admin.UsageStatisticIndexViewModel
@{
    ViewData["Title"] = "Usage Statistics";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Usage Statistics</h4>
        <p class="text-muted small mb-0">Page views and access logs for your website.</p>
    </div>
</div>

@* Filter Form *@
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-sm-3">
                <label class="form-label fw-medium small">Date From</label>
                <input type="date" name="dateFrom" class="form-control form-control-sm"
                       value="@Model.DateFrom.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-sm-3">
                <label class="form-label fw-medium small">Date To</label>
                <input type="date" name="dateTo" class="form-control form-control-sm"
                       value="@Model.DateTo.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-sm-4">
                <label class="form-label fw-medium small">Keyword</label>
                <input type="text" name="keyword" class="form-control form-control-sm"
                       placeholder="Page, path, username…" value="@Model.Keyword" />
            </div>
            <div class="col-sm-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

@* Summary Cards *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="flex-shrink-0 rounded-3 d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;background:#e8edff">
                    <i class="bi bi-activity fs-4" style="color:#2d4199"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalRequests.ToString("N0")</div>
                    <div class="text-muted small">Total Requests</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="flex-shrink-0 rounded-3 d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;background:#d1fae5">
                    <i class="bi bi-check-circle-fill fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold text-success">@Model.SuccessRequests.ToString("N0")</div>
                    <div class="text-muted small">Successful</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="flex-shrink-0 rounded-3 d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;background:#fee2e2">
                    <i class="bi bi-exclamation-circle-fill fs-4 text-danger"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold text-danger">@Model.FailedRequests.ToString("N0")</div>
                    <div class="text-muted small">Failed</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="flex-shrink-0 rounded-3 d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;background:#fef3c7">
                    <i class="bi bi-stopwatch-fill fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">@Model.AverageDurationMs.ToString("F0") ms</div>
                    <div class="text-muted small">Avg Duration</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">

    @* Daily Usage *@
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="fw-semibold mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>Daily Usage</h6>
                <span class="badge bg-secondary">@Model.DailyUsage.Count days</span>
            </div>
            <div class="card-body p-0">
                @if (Model.DailyUsage.Count == 0)
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No data in selected range.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Success</th>
                                    <th class="text-end">Failed</th>
                                    <th class="text-end">Avg (ms)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var day in Model.DailyUsage)
                                {
                                    <tr>
                                        <td class="fw-medium">@day.Date.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end">@day.TotalRequests.ToString("N0")</td>
                                        <td class="text-end text-success">@day.SuccessRequests.ToString("N0")</td>
                                        <td class="text-end @(day.FailedRequests > 0 ? "text-danger" : "text-muted")">@day.FailedRequests.ToString("N0")</td>
                                        <td class="text-end text-muted">@day.AverageDurationMs.ToString("F0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Top 10 Pages *@
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="fw-semibold mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Top Pages</h6>
                <span class="badge bg-secondary">top 10</span>
            </div>
            <div class="card-body p-0">
                @if (Model.TopPages.Count == 0)
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>No data.
                    </div>
                }
                else
                {
                    var maxCount = Model.TopPages.FirstOrDefault()?.Count ?? 1;
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Page</th>
                                    <th class="text-end">Hits</th>
                                    <th class="text-end">Avg (ms)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tp in Model.TopPages)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-medium small">@tp.PageName</div>
                                            <div class="progress mt-1" style="height:3px">
                                                <div class="progress-bar" style="width:@((tp.Count * 100 / maxCount))%;background:#2d4199"></div>
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold">@tp.Count.ToString("N0")</td>
                                        <td class="text-end text-muted small">@tp.AverageDurationMs.ToString("F0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@* Latest Logs *@
<div class="card shadow-sm">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="fw-semibold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Latest Requests</h6>
        <span class="badge bg-secondary">last @Model.LatestLogs.Count</span>
    </div>
    <div class="card-body p-0">
        @if (Model.LatestLogs.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>No logs in selected range.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0 align-middle" style="font-size:.82rem">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:130px">Date/Time</th>
                            <th>Page</th>
                            <th>Function</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th class="text-end">ms</th>
                            <th>User</th>
                            <th>IP</th>
                            <th>Lang</th>
                            <th style="min-width:200px">URL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.LatestLogs)
                        {
                            <tr>
                                <td class="text-nowrap text-muted">@log.AccessedAt.ToString("MM-dd HH:mm:ss")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.PageName))
                                    {
                                        <span class="badge bg-light text-dark border">@log.PageName</span>
                                    }
                                </td>
                                <td class="text-muted">@log.FunctionName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.HttpMethod))
                                    {
                                        var methodColor = log.HttpMethod switch
                                        {
                                            "GET"    => "primary",
                                            "POST"   => "success",
                                            "PUT"    => "warning",
                                            "DELETE" => "danger",
                                            _        => "secondary"
                                        };
                                        <span class="badge bg-@methodColor bg-opacity-10 text-@methodColor border border-@methodColor border-opacity-25">@log.HttpMethod</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var sc = log.StatusCode;
                                        var statusColor = sc >= 500 ? "danger" : sc >= 400 ? "warning" : "success";
                                    }
                                    <span class="badge bg-@statusColor bg-opacity-15 text-@statusColor border border-@statusColor border-opacity-25">@sc</span>
                                </td>
                                <td class="text-end text-muted">@log.DurationMs</td>
                                <td class="text-muted">@log.Username</td>
                                <td class="text-muted text-nowrap">@log.IpAddress</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.Language))
                                    {
                                        <span class="badge bg-secondary bg-opacity-15 text-secondary border">@log.Language.ToUpper()</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.Path))
                                    {
                                        var displayUrl = log.Path.Length > 40 ? log.Path[..40] + "…" : log.Path;
                                        <span title="@log.PageUrl" class="text-muted">@displayUrl</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
