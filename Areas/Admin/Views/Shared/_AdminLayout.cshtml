@using System.Security.Claims
@{
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
    var initial  = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "A";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Neediss Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --admin-primary : #2d4199;
            --admin-dark    : #111a4c;
            --sidebar-w     : 240px;
        }
        body { background: #f3f5f9; font-size: .925rem; }

        /* ── Sidebar ── */
        .admin-sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--admin-dark);
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: 1rem;
            color: #fff;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: .02em;
            border-bottom: 1px solid rgba(255,255,255,.07);
            text-decoration: none;
        }
        .sidebar-brand:hover { color: #fff; }
        .brand-icon {
            width: 30px; height: 30px;
            background: var(--admin-primary);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: .85rem; flex-shrink: 0;
        }
        .sidebar-section {
            font-size: .67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(255,255,255,.28);
            padding: .85rem 1rem .2rem;
        }
        .sidebar-nav { padding: 0 .5rem; }
        .sidebar-nav .nav-link {
            color: rgba(255,255,255,.58);
            border-radius: 7px;
            padding: .42rem .75rem;
            display: flex;
            align-items: center;
            gap: .55rem;
            font-size: .875rem;
            transition: background .15s, color .15s;
        }
        .sidebar-nav .nav-link i { font-size: .95rem; flex-shrink: 0; }
        .sidebar-nav .nav-link:hover { color: #fff; background: rgba(255,255,255,.09); }
        .sidebar-nav .nav-link.active {
            color: #fff;
            background: var(--admin-primary);
            font-weight: 600;
        }
        .sidebar-footer {
            margin-top: auto;
            padding: .75rem 1rem;
            border-top: 1px solid rgba(255,255,255,.07);
            font-size: .75rem;
            color: rgba(255,255,255,.25);
        }

        /* ── Topbar ── */
        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid #e4e8f0;
            padding: .5rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-shrink: 0;
        }
        .topbar-title { font-weight: 600; color: #2c3563; font-size: .9rem; }
        .admin-avatar {
            width: 32px; height: 32px;
            background: var(--admin-primary);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: .8rem; font-weight: 700; flex-shrink: 0;
        }
        .btn-logout { border-color: #dde3ef; color: #5a6380; font-size: .82rem; }
        .btn-logout:hover { border-color: #c0c8db; background: #f7f8fc; }

        /* ── Content ── */
        .admin-content { padding: 1.5rem; flex-grow: 1; }

        /* Mobile offcanvas sidebar style */
        #mobileSidebar { border: none; }
        #mobileSidebar .offcanvas-body { padding: 0; display: flex; flex-direction: column; }
    </style>
</head>
<body>

@* Mobile offcanvas sidebar *@
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileSidebar"
     style="width:var(--sidebar-w); background:var(--admin-dark)">
    <div class="offcanvas-header" style="border-bottom:1px solid rgba(255,255,255,.07); padding:.9rem 1rem">
        <div class="d-flex align-items-center gap-2">
            <div class="brand-icon"><i class="bi bi-layers-half text-white"></i></div>
            <span class="text-white fw-bold">Neediss Admin</span>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        @await Html.PartialAsync("_SidebarNav", ctrl)
        <div class="sidebar-footer">Neediss Back Office</div>
    </div>
</div>

<div class="d-flex" style="min-height:100vh">

    @* Desktop sidebar *@
    <aside class="admin-sidebar d-none d-lg-flex">
        <a class="sidebar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <div class="brand-icon"><i class="bi bi-layers-half text-white"></i></div>
            Neediss Admin
        </a>
        @await Html.PartialAsync("_SidebarNav", ctrl)
        <div class="sidebar-footer">Neediss Back Office</div>
    </aside>

    <div class="flex-grow-1 d-flex flex-column" style="min-width:0">

        @* Topbar *@
        <header class="admin-topbar">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm d-lg-none" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar"
                        aria-label="Open sidebar">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>

            <div class="d-flex align-items-center gap-2">
                <div class="admin-avatar d-none d-sm-flex">@initial</div>
                <span class="text-secondary small fw-semibold d-none d-md-inline">@fullName</span>
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-sm btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="d-none d-sm-inline ms-1">Sign Out</span>
                    </button>
                </form>
            </div>
        </header>

        @* Page content *@
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/admin-wysiwyg-editor.js" asp-append-version="true"></script>
<script src="~/js/admin-upload-preview.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
