            </a>
        }
        @if (await PermSvc.HasPermissionAsync(User, "AdminUser.View"))
        {
            <a class="nav-link @Active("AdminUser")"
               asp-area="Admin" asp-controller="AdminUser" asp-action="Index">
                <i class="bi bi-people"></i> Admin Users
            </a>
        }
        @if (await PermSvc.HasPermissionAsync(User, "Role.View"))
        {
            <a class="nav-link @Active("AdminRole")"
               asp-area="Admin" asp-controller="AdminRole" asp-action="Index">
                <i class="bi bi-shield-lock"></i> Roles & Permissions
            </a>
        }
    </nav>
}
