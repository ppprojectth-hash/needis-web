@model string
@inject Needis.Web.Services.Permissions.IPermissionService PermSvc
@{
    string Active(string controller) =>
        string.Equals(Model, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<div class="sidebar-section">Main</div>
<nav class="sidebar-nav nav flex-column gap-1 mb-2">
    @if (await PermSvc.HasPermissionAsync(User, "Dashboard.View"))
    {
        <a class="nav-link @Active("Dashboard")"
           asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
    }
</nav>

@if (await PermSvc.HasPermissionAsync(User, "Banner.View") ||
     await PermSvc.HasPermissionAsync(User, "HomePopup.View") ||
     await PermSvc.HasPermissionAsync(User, "Category.View") ||
     await PermSvc.HasPermissionAsync(User, "Product.View"))
{
    <div class="sidebar-section">Content</div>
    <nav class="sidebar-nav nav flex-column gap-1 mb-2">
        @if (await PermSvc.HasPermissionAsync(User, "Banner.View"))
        {
            <a class="nav-link @Active("Banner")"
               asp-area="Admin" asp-controller="Banner" asp-action="Index">
                <i class="bi bi-images"></i> Home Banners
            </a>
        }
        @if (await PermSvc.HasPermissionAsync(User, "HomePopup.View"))
        {
            <a class="nav-link @Active("HomePopup")"
               asp-area="Admin" asp-controller="HomePopup" asp-action="Index">
                <i class="bi bi-megaphone"></i> Home Popups
            </a>
        }
        @if (await PermSvc.HasPermissionAsync(User, "Category.View"))
        {
            <a class="nav-link @Active("Category")"
               asp-area="Admin" asp-controller="Category" asp-action="Index">
                <i class="bi bi-grid"></i> Categories
            </a>
        }
        @if (await PermSvc.HasPermissionAsync(User, "Product.View"))
        {
            <a class="nav-link @Active("Product")"
               asp-area="Admin" asp-controller="Product" asp-action="Index">
                <i class="bi bi-box-seam"></i> Products
            </a>
        }
    </nav>
}

@if (await PermSvc.HasPermissionAsync(User, "About.View"))
{
    <div class="sidebar-section">About Us</div>
    <nav class="sidebar-nav nav flex-column gap-1 mb-2">
        <a class="nav-link @Active("AboutSection")"
           asp-area="Admin" asp-controller="AboutSection" asp-action="Index">
            <i class="bi bi-layout-text-sidebar"></i> About Sections
        </a>
        <a class="nav-link @Active("AboutHistory")"
           asp-area="Admin" asp-controller="AboutHistory" asp-action="Index">
            <i class="bi bi-clock-history"></i> Company History
        </a>
        <a class="nav-link @Active("AboutStatCard")"
           asp-area="Admin" asp-controller="AboutStatCard" asp-action="Index">
            <i class="bi bi-123"></i> Stat Cards
        </a>
        <a class="nav-link @Active("BrandPartner")"
           asp-area="Admin" asp-controller="BrandPartner" asp-action="Index">
            <i class="bi bi-award"></i> Brand Partners
        </a>
        <a class="nav-link @Active("StaffProfile")"
           asp-area="Admin" asp-controller="StaffProfile" asp-action="Index">
            <i class="bi bi-person-badge"></i> Staff Profiles
        </a>
        <a class="nav-link @Active("ProductSale")"
           asp-area="Admin" asp-controller="ProductSale" asp-action="Index">
            <i class="bi bi-receipt"></i> Product Sales
        </a>
    </nav>
}

@if (await PermSvc.HasPermissionAsync(User, "Service.View"))
