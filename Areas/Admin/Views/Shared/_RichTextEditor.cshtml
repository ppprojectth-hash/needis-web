@model Needis.Web.ViewModels.Admin.RichTextEditorFieldViewModel
@{
    var id = string.IsNullOrEmpty(Model.FieldId) ? Model.FieldName : Model.FieldId;
    var isTh = Model.Language == "th";
    var placeholder = Model.Placeholder ?? (isTh ? "พิมพ์ข้อความ..." : "Type text...");
    var minHeight = Math.Max(Model.Rows, 3) * 28;
}
<div class="wysiwyg-editor-wrap">
    <div class="wysiwyg-toolbar">
        <button type="button" data-command="bold" title="@(isTh ? "ตัวหนา" : "Bold")">
            <strong>B</strong>
        </button>
        <button type="button" data-command="insertUnorderedList" title="@(isTh ? "รายการ bullet" : "Bullet list")">
            &bull;
        </button>
        <button type="button" data-command="insertOrderedList" title="@(isTh ? "รายการตัวเลข" : "Numbered list")">
            1.
        </button>
        <button type="button" data-command="heading" title="@(isTh ? "หัวข้อ" : "Heading")">
            H
        </button>
    </div>
    <div class="wysiwyg-editor"
         contenteditable="true"
         data-target="#@id"
         data-placeholder="@placeholder"
         style="min-height:@(minHeight)px"></div>
    <textarea name="@Model.FieldName" id="@id" class="d-none">@Model.Value</textarea>
</div>
<div class="wysiwyg-help">
    @(isTh
        ? "เลือกข้อความแล้วกดปุ่มด้านบนเพื่อจัดรูปแบบ"
        : "Select text and use the buttons above to format it.")
</div>
