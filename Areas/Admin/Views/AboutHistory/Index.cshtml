@model List<Needis.Web.Models.AboutCompanyHistory>
@{ ViewData["Title"] = "Company History"; }

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search title..." style="width:220px" />
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Event</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:80px">Year</th>
                    <th>Title EN</th>
                    <th>Title TH</th>
                    <th class="text-center" style="width:80px">Position</th>
                    <th class="text-center" style="width:70px">Order</th>
                    <th class="text-center" style="width:80px">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold">@h.Year</td>
                        <td>@h.TitleEN</td>
                        <td class="text-muted small">@h.TitleTH</td>
                        <td class="text-center"><span class="badge bg-light text-dark border">@(h.Position ?? "—")</span></td>
                        <td class="text-center">@h.DisplayOrder</td>
                        <td class="text-center">
                            <span class="badge @(h.IsActive ? "bg-success" : "bg-secondary")">@(h.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td class="text-end pe-3">
                            <a asp-action="Edit" asp-route-id="@h.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@h.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this history event?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">No history events found.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
