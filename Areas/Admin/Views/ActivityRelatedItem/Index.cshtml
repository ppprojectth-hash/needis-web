@model List<Needis.Web.Models.ActivityRelatedItem>
@{
    var activity = ViewBag.Activity as Needis.Web.Models.Activity;
    ViewData["Title"] = "Related Items";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Activity" asp-action="Index">Activities</a></li>
        <li class="breadcrumb-item active">@(activity?.ActivityTitleEN ?? "Activity") — Related</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <div class="text-muted small">Manage related activities</div>
    <div class="d-flex gap-2">
        <a asp-controller="Activity" asp-action="Details" asp-route-id="@activity?.Id"
           class="btn btn-sm btn-outline-secondary">Details</a>
        <a asp-action="Create" asp-route-activityId="@activity?.Id" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Related
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Related Activity</th>
                    <th class="text-center">Order</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var relItem in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="fw-medium">@relItem.RelatedActivity?.ActivityTitleEN</div>
                            <div class="text-muted small"><code>@relItem.RelatedActivity?.ActivitySlug</code></div>
                        </td>
                        <td class="text-center">@relItem.DisplayOrder</td>
                        <td class="text-center">
                            @if (relItem.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="actions-cell pe-3">
                            <div class="admin-actions">
                                <a asp-action="Edit" asp-route-id="@relItem.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit related item">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@relItem.Id" method="post"
                                      class="admin-action-form"
                                      onsubmit="return confirm('Remove this related activity?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="admin-action-btn admin-action-btn-delete"
                                            title="Remove" aria-label="Remove related item">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No related activities.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
