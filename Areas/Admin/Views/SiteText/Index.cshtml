@model List<Needis.Web.Models.SiteText>
@{ ViewData["Title"] = "Website Texts"; }

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search key, label, TH/EN text..." style="width:260px" />
        <select name="page" class="form-select form-select-sm" style="width:180px">
            <option value="">All Pages</option>
            @foreach (var p in (List<string>)ViewBag.Pages)
            {
                <option value="@p" selected="@(p == (string?)ViewBag.Page ? "selected" : null)">@p</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string) || !string.IsNullOrEmpty(ViewBag.Page as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Text</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Page</th>
                    <th>Section</th>
                    <th>Label</th>
                    <th>Key</th>
                    <th>Thai Text</th>
                    <th>English Text</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    string Preview(string? s) => string.IsNullOrEmpty(s) ? "—" : (s.Length > 40 ? s[..40] + "…" : s);
                    <tr>
                        <td><span class="badge bg-light text-dark border">@t.Page</span></td>
                        <td class="text-muted small">@(t.Section ?? "—")</td>
                        <td class="fw-semibold">@t.Label</td>
                        <td><code class="small">@t.Key</code></td>
                        <td class="small">@Preview(t.TextTH)</td>
                        <td class="small">@Preview(t.TextEN)</td>
                        <td class="text-center">
                            <span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td class="actions-cell pe-3">
                            <div class="admin-actions">
                                <a asp-action="Edit" asp-route-id="@t.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit website text">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="8" class="text-center text-muted py-4">No website texts found.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
