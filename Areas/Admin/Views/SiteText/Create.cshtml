@model Needis.Web.ViewModels.Admin.SiteTextViewModel
@{ ViewData["Title"] = "Add Website Text"; }

<div class="card border-0 shadow-sm rounded-3 mx-auto" style="max-width:720px">
    <div class="card-body p-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Key" class="form-label fw-medium">Key <span class="text-danger">*</span></label>
                    <input asp-for="Key" class="form-control" placeholder="e.g. home.hero.title" />
                    <div class="form-text">This key is used by the website code. Do not change it unless you know what you are doing.</div>
                    <span asp-validation-for="Key" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Page" class="form-label fw-medium">Page <span class="text-danger">*</span></label>
                    <input asp-for="Page" class="form-control" placeholder="e.g. home" />
                    <span asp-validation-for="Page" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Section" class="form-label fw-medium">Section</label>
                    <input asp-for="Section" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Label" class="form-label fw-medium">Label <span class="text-danger">*</span></label>
                    <input asp-for="Label" class="form-control" placeholder="Short admin-facing name" />
                    <span asp-validation-for="Label" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TextTH" class="form-label fw-medium">Thai Text</label>
                    <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                        FieldName = "TextTH", Value = Model.TextTH, Rows = 3, Language = "th" }' />
                </div>
                <div class="col-md-6">
                    <label asp-for="TextEN" class="form-label fw-medium">English Text</label>
                    <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                        FieldName = "TextEN", Value = Model.TextEN, Rows = 3, Language = "en" }' />
                </div>
                <div class="col-md-8">
                    <label asp-for="Description" class="form-label fw-medium">Description</label>
                    <input asp-for="Description" class="form-control" placeholder="Where/how this text is used" />
                </div>
                <div class="col-md-4">
                    <label asp-for="TextType" class="form-label fw-medium">Text Type</label>
                    <select asp-for="TextType" class="form-select">
                        <option value="text">text</option>
                        <option value="textarea">textarea</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DisplayOrder" class="form-label fw-medium">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-8 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
