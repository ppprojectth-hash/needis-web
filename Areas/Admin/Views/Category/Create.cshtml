@model Needis.Web.ViewModels.Admin.ProductCategoryViewModel
@{
    ViewData["Title"] = "Add Category";
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h5 class="fw-bold mb-0">
                <i class="bi bi-plus-circle me-2" style="color:#2d4199"></i>Add Category
            </h5>
            <p class="text-muted small mb-0 mt-1">Create a new product category</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <button type="submit" class="btn btn-sm btn-primary px-3"
                    style="background:#2d4199;border-color:#2d4199">
                <i class="bi bi-save me-1"></i>Create Category
            </button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible d-flex align-items-start gap-2 rounded-3 mb-4">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <div><div asp-validation-summary="ModelOnly"></div></div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        @* ── Left: Category Information ── *@
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-translate me-2 text-primary"></i>Category Information
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="CategoryNameEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.CategoryNameEN) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CategoryNameEN" id="CategoryNameEN" class="form-control"
                                   placeholder="e.g. Measuring Instruments" />
                            <span asp-validation-for="CategoryNameEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="CategoryNameTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.CategoryNameTH)
                            </label>
                            <input asp-for="CategoryNameTH" class="form-control"
                                   placeholder="เช่น เครื่องมือวัด" />
                            <span asp-validation-for="CategoryNameTH" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.Slug) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Slug" id="Slug" class="form-control font-monospace"
                               placeholder="auto-generated from name" />
                        <div class="text-muted small mt-1">URL-safe identifier. Auto-filled from English name.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-0">
                        <div class="col-sm-6">
                            <label asp-for="ShortDescriptionEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ShortDescriptionEN)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "ShortDescriptionEN", Value = Model.ShortDescriptionEN, Rows = 3,
                                Placeholder = "Brief description in English", Language = "en" }' />
                            <span asp-validation-for="ShortDescriptionEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ShortDescriptionTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ShortDescriptionTH)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "ShortDescriptionTH", Value = Model.ShortDescriptionTH, Rows = 3,
                                Placeholder = "คำอธิบายสั้นภาษาไทย", Language = "th" }' />
                            <span asp-validation-for="ShortDescriptionTH" class="text-danger small"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        @* ── Right: Image + Settings ── *@
        <div class="col-lg-5">

            @* Category Image *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-image me-2 text-primary"></i>Category Image
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">
                    <div id="categoryImagePreviewWrap" class="admin-upload-preview-frame mb-3 d-none">
                        <img id="categoryImagePreview" src="#" alt="Preview" class="admin-image-preview" />
                    </div>
                    <input asp-for="ImageFile" type="file" class="form-control js-image-preview-input"
                           accept=".jpg,.jpeg,.png,.webp,.svg" id="ImageFileInput"
                           data-preview-target="#categoryImagePreview"
                           data-preview-wrapper="#categoryImagePreviewWrap"
                           data-size-target="#categoryImgSize" />
                    <span id="categoryImgSize" class="upload-file-meta"></span>
                    <span asp-validation-for="ImageFile" class="text-danger small d-block mt-1"></span>
                    <div class="text-muted small mt-2">
                        Recommended: <strong>1200 × 800 px</strong> &nbsp;·&nbsp;
                        JPG, PNG, WebP &nbsp;·&nbsp; Max 5 MB
                    </div>
                </div>
            </div>

            @* Display Settings *@
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-sliders me-2 text-primary"></i>Display Settings
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="mb-3">
                        <label asp-for="DisplayOrder" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.DisplayOrder)
                        </label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="0" max="9999" />
                        <div class="text-muted small mt-1">Lower numbers appear first.</div>
                        <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                    </div>

                    <div class="mb-0">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label small fw-semibold">Active</label>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
<script>
    // Auto-generate slug from English name
    const nameInput = document.getElementById('CategoryNameEN');
    const slugInput = document.getElementById('Slug');
    let slugEdited = false;

    slugInput.addEventListener('input', () => { slugEdited = true; });

    nameInput?.addEventListener('input', function () {
        if (slugEdited) return;
        let val = this.value.trim().toLowerCase()
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9\-]/g, '')
            .replace(/-{2,}/g, '-')
            .replace(/^-+|-+$/g, '');
        slugInput.value = val;
    });
</script>
}
