@model List<Needis.Web.Models.ActivityTag>
@{
    ViewData["Title"] = "Activity Tags";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search key, name..." style="width:240px" />
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Tag
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Tag Key</th>
                    <th>Name EN</th>
                    <th>Color</th>
                    <th class="text-center">Filterable</th>
                    <th class="text-center">Order</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    <tr>
                        <td class="ps-3"><code>@tag.TagKey</code></td>
                        <td>
                            <div class="fw-medium">@tag.TagNameEN</div>
                            <div class="text-muted small">@tag.TagNameTH</div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(tag.TagColor))
                            {
                                <span class="badge" style="background-color:@tag.TagColor">@tag.TagColor</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (tag.IsFilterable)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">@tag.DisplayOrder</td>
                        <td class="text-center">
                            @if (tag.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <a asp-action="Edit" asp-route-id="@tag.Id"
                               class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@tag.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this tag?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No tags found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
