@model AdminRoleDetailsViewModel
@{
    ViewData["Title"] = $"Role: {Model.RoleName}";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h5 class="fw-bold mb-0">@Model.RoleName</h5>
        <p class="text-muted small mb-0">
            <code>@Model.RoleKey</code>
            @if (Model.IsSystem) { <span class="badge bg-primary ms-1" style="font-size:.7rem">System</span> }
        </p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Permissions" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
            <i class="bi bi-key me-1"></i>Permissions
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fw-bold fs-3" style="color:#2d4199">@Model.PermissionGroups.Sum(g => g.Permissions.Count(p => p.IsSelected))</div>
            <div class="text-muted small">Permissions</div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fw-bold fs-3" style="color:#2d4199">@Model.UserCount</div>
            <div class="text-muted small">Active Users</div>
        </div>
    </div>
</div>

@foreach (var group in Model.PermissionGroups)
{
    <div class="card border-0 shadow-sm rounded-3 mb-3">
        <div class="card-header py-2 bg-light">
            <span class="fw-semibold small text-uppercase" style="letter-spacing:.06em">@group.GroupName</span>
        </div>
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var p in group.Permissions)
                {
                    <span class="badge @(p.IsSelected ? "bg-primary" : "bg-light text-muted border") py-1 px-2">
                        @if (p.IsSelected) { <i class="bi bi-check me-1"></i> }
                        @p.PermissionName
                    </span>
                }
            </div>
        </div>
    </div>
}
