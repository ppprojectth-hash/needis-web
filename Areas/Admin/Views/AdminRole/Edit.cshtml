@model AdminRoleEditViewModel
@{
    ViewData["Title"] = $"Edit Role: {Model.RoleName}";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h5 class="fw-bold mb-0">Edit Role</h5>
        <p class="text-muted small mb-0"><code>@Model.RoleKey</code></p>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" style="max-width:600px">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RoleKey" />
    <input type="hidden" asp-for="IsSystem" />

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body">
            @if (Model.IsSystem)
            {
                <div class="alert alert-info py-2 mb-3" style="font-size:.84rem">
                    <i class="bi bi-shield-check me-1"></i>
                    This is a system role. The <strong>Role Key</strong> cannot be changed.
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-medium small">Role Key</label>
                <input class="form-control" value="@Model.RoleKey" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="RoleName" class="form-label fw-medium small"></label>
                <input asp-for="RoleName" class="form-control" />
                <span asp-validation-for="RoleName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-medium small"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-floppy-fill me-1"></i>Save Changes
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
