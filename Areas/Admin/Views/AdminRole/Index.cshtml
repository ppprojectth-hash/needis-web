@model List<AdminRoleListItemViewModel>
@{
    ViewData["Title"] = "Roles & Permissions";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-bold mb-0">Roles &amp; Permissions</h5>
        <p class="text-muted small mb-0">Manage role definitions and their permission sets.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Role</th>
                        <th>Key</th>
                        <th class="text-center">Permissions</th>
                        <th class="text-center">Users</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">System</th>
                        <th class="pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="fw-semibold">@r.RoleName</div>
                                @if (!string.IsNullOrEmpty(r.Description))
                                {
                                    <div class="text-muted small">@r.Description</div>
                                }
                            </td>
                            <td><code class="text-primary">@r.RoleKey</code></td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@r.PermissionCount</span>
                            </td>
                            <td class="text-center">@r.UserCount</td>
                            <td class="text-center">
                                @if (r.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (r.IsSystem)
                                {
                                    <i class="bi bi-shield-check text-primary" title="System role"></i>
                                }
                            </td>
                            <td class="pe-3">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@r.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@r.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Permissions" asp-route-id="@r.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-key"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
