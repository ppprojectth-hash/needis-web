@model IEnumerable<Needis.Web.ViewModels.Admin.SeoSettingListItemViewModel>
@{
    ViewData["Title"] = "SEO Settings";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var entityTypes = ViewBag.EntityTypes as List<string> ?? new List<string>();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">SEO Settings</h4>
        <p class="text-muted small mb-0">Manage meta tags, Open Graph, and sitemap inclusion</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/sitemap.xml" target="_blank" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-diagram-3 me-1"></i>View Sitemap
        </a>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add SEO Setting
        </a>
    </div>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-medium mb-1">Search</label>
                <input name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
                       placeholder="Page key, title, route, entity type..." />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-medium mb-1">Entity Type</label>
                <select name="entityType" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var et in entityTypes)
                    {
                        <option value="@et" selected="@(ViewBag.EntityType == et ? "selected" : null)">@et</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Page Key</th>
                    <th>Entity</th>
                    <th>Meta Title (EN)</th>
                    <th class="text-center">Sitemap</th>
                    <th class="text-center">Status</th>
                    <th>Updated</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-primary-subtle text-primary-emphasis">@item.PageKey</span>
                            @if (!string.IsNullOrEmpty(item.RoutePath))
                            {
                                <div class="small text-muted mt-1">@item.RoutePath</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.EntityType))
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">@item.EntityType</span>
                                @if (item.EntityId.HasValue)
                                {
                                    <span class="text-muted small ms-1">#@item.EntityId</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <div class="text-truncate" style="max-width:220px">
                                @(item.MetaTitleEN ?? item.MetaTitleTH ?? "—")
                            </div>
                        </td>
                        <td class="text-center">
                            @if (item.IncludeInSitemap)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle-fill text-secondary"></i>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Inactive</span>
                            }
                        </td>
                        <td class="small text-muted">
                            @(item.UpdatedAt?.ToString("dd MMM yyyy") ?? "—")
                        </td>
                        <td class="actions-cell">
                            <div class="admin-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit SEO setting">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      class="admin-action-form"
                                      onsubmit="return confirm('Delete this SEO setting?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="admin-action-btn admin-action-btn-delete"
                                            title="Delete" aria-label="Delete SEO setting">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No SEO settings found.
                            <a asp-action="Create" class="ms-2">Add one</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
