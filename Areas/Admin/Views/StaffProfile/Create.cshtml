@model Needis.Web.ViewModels.Admin.StaffProfileViewModel
@{ ViewData["Title"] = "Add Staff Profile"; }

<div class="mx-auto" style="max-width:860px">
    <div class="d-flex align-items-center gap-2 mb-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <h5 class="mb-0 fw-semibold">Add Staff Profile</h5>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        @* A. Basic Information *@
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                <h6 class="fw-semibold text-primary mb-0"><i class="bi bi-person-badge me-2"></i>Basic Information</h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="EmployeeCode" class="form-label fw-medium">Employee Code</label>
                        <input asp-for="EmployeeCode" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="StaffType" class="form-label fw-medium">Staff Type</label>
                        <select asp-for="StaffType" class="form-select">
                            <option value="">— Select —</option>
                            <option value="FullTime">Full Time</option>
                            <option value="PartTime">Part Time</option>
                            <option value="Consultant">Consultant</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Department" class="form-label fw-medium">Department</label>
                        <input asp-for="Department" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FullNameEN" class="form-label fw-medium">Full Name EN <span class="text-danger">*</span></label>
                        <input asp-for="FullNameEN" class="form-control" />
                        <span asp-validation-for="FullNameEN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FullNameTH" class="form-label fw-medium">Full Name TH</label>
                        <input asp-for="FullNameTH" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PositionEN" class="form-label fw-medium">Position EN</label>
                        <input asp-for="PositionEN" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PositionTH" class="form-label fw-medium">Position TH</label>
                        <input asp-for="PositionTH" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Slug" class="form-label fw-medium">Slug <span class="text-muted small fw-normal">(auto-generated if blank)</span></label>
                        <input asp-for="Slug" class="form-control font-monospace" placeholder="e.g. john-doe" />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DisplayOrder" class="form-label fw-medium">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-medium">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control admin-date-input"
                               asp-format="{0:yyyy-MM-dd}" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-medium">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control admin-date-input"
                               asp-format="{0:yyyy-MM-dd}" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-4 pt-1">
                        <div class="form-check">
                            <input asp-for="IsExpert" type="checkbox" class="form-check-input" />
                            <label asp-for="IsExpert" class="form-check-label fw-medium">Is Expert <span class="text-muted small">(counts in stat card)</span></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="ShowPublic" type="checkbox" class="form-check-input" />
                            <label asp-for="ShowPublic" class="form-check-label fw-medium">Show Publicly on About page</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
                            <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* B. Contact Information *@
        @if (FF.StaffProfileDetailEnabled)
        {
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                <h6 class="fw-semibold text-primary mb-0"><i class="bi bi-telephone me-2"></i>Contact Information</h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="MobilePhone" class="form-label fw-medium">Mobile Phone</label>
                        <input asp-for="MobilePhone" class="form-control" placeholder="e.g. 081-234-5678" />
                        <span asp-validation-for="MobilePhone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-medium">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input asp-for="ShowContactInfo" type="checkbox" class="form-check-input" role="switch" checked />
                            <label asp-for="ShowContactInfo" class="form-check-label fw-medium">Show contact info publicly on staff detail page</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        } @* end StaffProfileDetailEnabled (B) *@

        @* C. Profile Detail *@
        @if (FF.StaffProfileDetailEnabled)
        {
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                <h6 class="fw-semibold text-primary mb-0"><i class="bi bi-journal-text me-2"></i>Profile Detail</h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="BiographyEN" class="form-label fw-medium">Biography (EN)</label>
                        <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                            FieldName = "BiographyEN", Value = Model.BiographyEN, Rows = 5,
                            Placeholder = "Brief biography in English...", Language = "en" }' />
                        <span asp-validation-for="BiographyEN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BiographyTH" class="form-label fw-medium">Biography (TH)</label>
                        <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                            FieldName = "BiographyTH", Value = Model.BiographyTH, Rows = 5,
                            Placeholder = "ประวัติย่อ...", Language = "th" }' />
                        <span asp-validation-for="BiographyTH" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AchievementEN" class="form-label fw-medium">Achievements / Experience (EN)</label>
                        <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                            FieldName = "AchievementEN", Value = Model.AchievementEN, Rows = 5,
                            Placeholder = "Key achievements and experience...", Language = "en" }' />
                        <span asp-validation-for="AchievementEN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AchievementTH" class="form-label fw-medium">Achievements / Experience (TH)</label>
                        <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                            FieldName = "AchievementTH", Value = Model.AchievementTH, Rows = 5,
                            Placeholder = "ผลงานและประสบการณ์...", Language = "th" }' />
                        <span asp-validation-for="AchievementTH" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input asp-for="ShowDetailPage" type="checkbox" class="form-check-input" role="switch" checked />
                            <label asp-for="ShowDetailPage" class="form-check-label fw-medium">Enable public detail page for this staff member</label>
                        </div>
                        <div class="text-muted small mt-1">When enabled, the staff card on the About page will show a "View Profile" button linking to <code>/About/Staff/{slug}</code>.</div>
                    </div>
                </div>
            </div>
        </div>
        } @* end StaffProfileDetailEnabled (C) *@

        @* D. Files *@
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                <h6 class="fw-semibold text-primary mb-0"><i class="bi bi-paperclip me-2"></i>Files</h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ImageFile" class="form-label fw-medium">Profile Photo</label>
                        <div class="mb-2 d-none" id="staffPhotoPreviewWrap">
                            <div class="staff-photo-frame" style="width:80px;height:80px">
                                <img id="staffPhotoPreview" src="#" alt="Preview" />
                            </div>
                        </div>
                        <input asp-for="ImageFile" type="file" class="form-control js-image-preview-input"
                               accept=".jpg,.jpeg,.png,.webp"
                               data-preview-target="#staffPhotoPreview"
                               data-preview-wrapper="#staffPhotoPreviewWrap"
                               data-size-target="#staffPhotoSize" />
                        <span id="staffPhotoSize" class="upload-file-meta"></span>
                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                        <div class="text-muted small mt-1">Recommended: 800×800 px or 4:5 portrait · JPG, PNG, WebP · Max 2 MB</div>
                    </div>
                    @if (FF.StaffProfileDetailEnabled)
                    {
                    <div class="col-md-6">
                        <label asp-for="PdfFile" class="form-label fw-medium">Profile PDF <span class="text-muted small fw-normal">(optional)</span></label>
                        <input asp-for="PdfFile" type="file" class="form-control js-file-meta-input" accept=".pdf"
                               data-size-target="#staffPdfSize" />
                        <span id="staffPdfSize" class="upload-file-meta"></span>
                        <span asp-validation-for="PdfFile" class="text-danger small"></span>
                        <div class="text-muted small mt-1">PDF only · Max 20 MB · Shown as download button on detail page</div>
                    </div>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-floppy me-1"></i>Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
