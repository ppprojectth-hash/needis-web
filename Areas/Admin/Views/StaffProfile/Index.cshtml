@model List<Needis.Web.Models.StaffProfile>
@{ ViewData["Title"] = "Staff Profiles"; }

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search name, code, dept..." style="width:240px" />
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string)) { <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a> }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Staff</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:50px">Photo</th>
                    <th>Full Name EN</th>
                    <th>Position EN</th>
                    <th>Code</th>
                    <th>Dept</th>
                    <th class="text-center">Expert</th>
                    <th class="text-center">Public</th>
                    <th class="text-center">Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty(s.ProfileImageUrl))
                            {
                                <img src="@s.ProfileImageUrl" alt="" class="rounded-circle" style="width:36px;height:36px;object-fit:cover;object-position:center top" />
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="fw-semibold">@(s.FullNameEN ?? "—")</td>
                        <td class="text-muted small">@(s.PositionEN ?? "—")</td>
                        <td><code class="small">@(s.EmployeeCode ?? "—")</code></td>
                        <td class="text-muted small">@(s.Department ?? "—")</td>
                        <td class="text-center">@if (s.IsExpert) { <i class="bi bi-star-fill text-warning"></i> } else { <i class="bi bi-dash text-muted"></i> }</td>
                        <td class="text-center">@if (s.ShowPublic) { <i class="bi bi-check-circle-fill text-success"></i> } else { <i class="bi bi-dash text-muted"></i> }</td>
                        <td class="text-center"><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-end pe-3">
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this staff profile?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="9" class="text-center text-muted py-4">No staff profiles found.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
