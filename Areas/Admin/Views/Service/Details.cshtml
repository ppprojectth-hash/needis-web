@model dynamic
@{
    ViewData["Title"] = $"Service Details — {Model.ServiceNameEN}";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Services
    </a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a asp-controller="ServiceDetailSection" asp-action="Index" asp-route-serviceId="@Model.Id"
       class="btn btn-sm btn-outline-info">
        <i class="bi bi-layout-text-sidebar me-1"></i>Manage Sections (@Model.SectionCount)
    </a>
    <a asp-controller="ServiceContactCard" asp-action="Index" asp-route-serviceId="@Model.Id"
       class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-card-text me-1"></i>Manage Contact Cards (@Model.CardCount)
    </a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-12 d-flex align-items-center gap-3 mb-2">
                        @if (!string.IsNullOrEmpty((string?)Model.CoverImageUrl))
                        {
                            <img src="@Model.CoverImageUrl" alt="cover" class="rounded" style="width:72px;height:72px;object-fit:cover" />
                        }
                        <div>
                            <h5 class="mb-1">@Model.ServiceNameEN</h5>
                            <div class="text-muted">@Model.ServiceNameTH</div>
                            <div class="mt-1">
                                <code class="me-2">@Model.ServiceCode</code>
                                <span class="badge bg-light text-dark border"><code>@Model.ServiceSlug</code></span>
                                @if ((bool)Model.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark ms-1"><i class="bi bi-star-fill me-1"></i>Featured</span>
                                }
                                @if ((bool)Model.IsActive)
                                {
                                    <span class="badge bg-success ms-1">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary ms-1">Inactive</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12"><hr class="my-1" /></div>

                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Short Description EN</div>
                        <div>@(Model.ShortDescriptionEN ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Short Description TH</div>
                        <div>@(Model.ShortDescriptionTH ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Detail Title EN</div>
                        <div>@(Model.DetailTitleEN ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Detail Title TH</div>
                        <div>@(Model.DetailTitleTH ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Detail Subtitle EN</div>
                        <div>@(Model.DetailSubtitleEN ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small fw-medium mb-1">Detail Subtitle TH</div>
                        <div>@(Model.DetailSubtitleTH ?? "—")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">Images</h6>
                @if (!string.IsNullOrEmpty((string?)Model.BannerImageUrl))
                {
                    <div class="mb-2">
                        <div class="text-muted small mb-1">Banner</div>
                        <img src="@Model.BannerImageUrl" alt="banner" class="img-thumbnail w-100" style="max-height:120px;object-fit:cover" />
                    </div>
                }
                @if (!string.IsNullOrEmpty((string?)Model.IconUrl))
                {
                    <div>
                        <div class="text-muted small mb-1">Icon</div>
                        <img src="@Model.IconUrl" alt="icon" class="img-thumbnail" style="max-height:60px" />
                    </div>
                }
                @if (string.IsNullOrEmpty((string?)Model.BannerImageUrl) && string.IsNullOrEmpty((string?)Model.IconUrl))
                {
                    <div class="text-muted">No images uploaded.</div>
                }

                <hr />
                <h6 class="fw-bold mb-2">Metadata</h6>
                <div class="text-muted small">
                    <div>Order: @Model.DisplayOrder</div>
                    <div>Created: @Model.CreatedAt.ToString("dd MMM yyyy") by @(Model.CreatedBy ?? "—")</div>
                    @if (Model.UpdatedAt != null)
                    {
                        <div>Updated: @((DateTime)Model.UpdatedAt).ToString("dd MMM yyyy") by @(Model.UpdatedBy ?? "—")</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
