@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Services";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search code, slug, name..." style="width:260px" />
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Service
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:60px">Cover</th>
                    <th>Code</th>
                    <th>Name EN</th>
                    <th>Slug</th>
                    <th class="text-center">Featured</th>
                    <th class="text-center">Active</th>
                    <th class="text-center">Sections</th>
                    <th class="text-center">Cards</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var svc in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty((string?)svc.CoverImageUrl))
                            {
                                <img src="@svc.CoverImageUrl" alt="" class="rounded" style="width:44px;height:44px;object-fit:cover" />
                                <div class="admin-file-size mt-1">@FileInfoSvc.GetFileSizeDisplay(svc.CoverImageUrl)</div>
                            }
                            else
                            {
                                <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:44px;height:44px">
                                    <i class="bi bi-tools text-muted"></i>
                                </div>
                            }
                        </td>
                        <td><code>@svc.ServiceCode</code></td>
                        <td>
                            <div class="fw-medium">@svc.ServiceNameEN</div>
                            <div class="text-muted small">@svc.ServiceNameTH</div>
                        </td>
                        <td class="text-muted small"><code>@svc.ServiceSlug</code></td>
                        <td class="text-center">
                            @if ((bool)svc.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Featured</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if ((bool)svc.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-controller="ServiceDetailSection" asp-action="Index" asp-route-serviceId="@svc.Id"
                               class="badge bg-info text-dark text-decoration-none">@svc.SectionCount Sections</a>
                        </td>
                        <td class="text-center">
                            <a asp-controller="ServiceContactCard" asp-action="Index" asp-route-serviceId="@svc.Id"
                               class="badge bg-secondary text-decoration-none">@svc.CardCount Cards</a>
                        </td>
                        <td class="actions-cell pe-3">
                            <div class="admin-actions">
                                <a asp-action="Details" asp-route-id="@svc.Id"
                                   class="admin-action-btn admin-action-btn-view"
                                   title="View Details" aria-label="View service details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@svc.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit service">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@svc.Id" method="post"
                                      class="admin-action-form"
                                      onsubmit="return confirm('Delete this service?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="admin-action-btn admin-action-btn-delete"
                                            title="Delete" aria-label="Delete service">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No services found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
