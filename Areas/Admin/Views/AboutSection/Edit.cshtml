@model Needis.Web.ViewModels.Admin.AboutSectionViewModel
@{
    ViewData["Title"] = "Edit About Section";
    string[] layouts = ["text_left", "text_right", "text_center", "cards", "timeline"];
}

<div class="card border-0 shadow-sm rounded-3 mx-auto" style="max-width:760px">
    <div class="card-body p-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="SectionKey" class="form-label fw-medium">Section Key <span class="text-danger">*</span></label>
                    <input asp-for="SectionKey" class="form-control" />
                    <span asp-validation-for="SectionKey" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LayoutType" class="form-label fw-medium">Layout Type</label>
                    <select asp-for="LayoutType" class="form-select">
                        <option value="">— Select —</option>
                        @foreach (var l in layouts)
                        {
                            <option value="@l" selected="@(Model.LayoutType == l ? "selected" : null)">@l</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TitleEN" class="form-label fw-medium">Title EN <span class="text-danger">*</span></label>
                    <input asp-for="TitleEN" class="form-control" />
                    <span asp-validation-for="TitleEN" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TitleTH" class="form-label fw-medium">Title TH</label>
                    <input asp-for="TitleTH" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SubtitleEN" class="form-label fw-medium">Subtitle EN</label>
                    <input asp-for="SubtitleEN" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="SubtitleTH" class="form-label fw-medium">Subtitle TH</label>
                    <input asp-for="SubtitleTH" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="DescriptionEN" class="form-label fw-medium">Description EN</label>
                    <textarea asp-for="DescriptionEN" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="DescriptionTH" class="form-label fw-medium">Description TH</label>
                    <textarea asp-for="DescriptionTH" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="ImageFile" class="form-label fw-medium">Image</label>
                    @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ExistingImageUrl" alt="current" class="img-thumbnail" style="max-height:80px" />
                        </div>
                    }
                    <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,.svg" />
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                    <div class="text-muted small mt-2">Recommended: <strong>1200 × 800 px</strong> &nbsp;·&nbsp; JPG, PNG, WebP &nbsp;·&nbsp; Max 5 MB &nbsp;·&nbsp; Leave empty to keep current.</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="DisplayOrder" class="form-label fw-medium">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
