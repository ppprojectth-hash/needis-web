@using ActivityModel = Needis.Web.Models.Activity
@model List<ActivityModel>
@{
    ViewData["Title"] = "Activities";
    var allTags = ViewBag.AllTags as List<Needis.Web.Models.ActivityTag> ?? new();
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm"
               placeholder="Search slug, title, author..." style="width:240px" />
        <select name="tag" class="form-select form-select-sm" style="width:160px">
            <option value="">All Tags</option>
            @foreach (var t in allTags)
            {
                <option value="@t.TagKey" selected="@(ViewBag.Tag == t.TagKey ? "selected" : null)">@t.TagNameEN</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-primary">Filter</button>
        @if (!string.IsNullOrEmpty(ViewBag.Keyword as string) || !string.IsNullOrEmpty(ViewBag.Tag as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Activity
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:60px">Cover</th>
                    <th>Title EN</th>
                    <th>Tags</th>
                    <th>Published</th>
                    <th class="text-center">Featured</th>
                    <th class="text-center">Published</th>
                    <th class="text-center">Active</th>
                    <th class="text-center">Views</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var activity in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty(activity.CoverImageUrl))
                            {
                                <img src="@activity.CoverImageUrl" alt="" class="rounded" style="width:44px;height:44px;object-fit:cover" />
                                <div class="admin-file-size mt-1">@FileInfoSvc.GetFileSizeDisplay(activity.CoverImageUrl)</div>
                            }
                            else
                            {
                                <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:44px;height:44px">
                                    <i class="bi bi-newspaper text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-medium">@activity.ActivityTitleEN</div>
                            <div class="text-muted small"><code>@activity.ActivitySlug</code></div>
                        </td>
                        <td>
                            @foreach (var tagMap in activity.ActivityTagMaps.Where(m => m.ActivityTag != null && !m.ActivityTag.IsDelete))
                            {
                                var color = tagMap.ActivityTag!.TagColor ?? "#6c757d";
                                <span class="badge me-1" style="background-color:@color">
                                    @tagMap.ActivityTag.TagNameEN
                                    @if (tagMap.IsPrimary) { <i class="bi bi-star-fill ms-1"></i> }
                                </span>
                            }
                        </td>
                        <td class="text-muted small">
                            @(activity.PublishedDate.HasValue ? activity.PublishedDate.Value.ToString("dd MMM yyyy") : "—")
                        </td>
                        <td class="text-center">
                            @if (activity.IsFeatured)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Featured</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (activity.IsPublished)
                            {
                                <span class="badge bg-primary">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Draft</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (activity.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-center text-muted small">@activity.ViewCount</td>
                        <td class="actions-cell pe-3">
                            <div class="admin-actions">
                                <a asp-action="Edit" asp-route-id="@activity.Id"
                                   class="admin-action-btn admin-action-btn-edit"
                                   title="Edit" aria-label="Edit activity">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="ManageTags" asp-route-id="@activity.Id"
                                   class="admin-action-btn admin-action-btn-secondary"
                                   title="Manage Tags" aria-label="Manage tags">
                                    <i class="bi bi-tags"></i>
                                </a>
                                <a asp-controller="ActivityDetailBlock" asp-action="Index" asp-route-activityId="@activity.Id"
                                   class="admin-action-btn admin-action-btn-secondary"
                                   title="Detail Blocks" aria-label="Detail blocks">
                                    <i class="bi bi-layout-text-sidebar"></i>
                                </a>
                                <a asp-controller="ActivityImage" asp-action="Index" asp-route-activityId="@activity.Id"
                                   class="admin-action-btn admin-action-btn-secondary"
                                   title="Images" aria-label="Manage images">
                                    <i class="bi bi-images"></i>
                                </a>
                                <a asp-controller="ActivityRelatedItem" asp-action="Index" asp-route-activityId="@activity.Id"
                                   class="admin-action-btn admin-action-btn-secondary"
                                   title="Related" aria-label="Related items">
                                    <i class="bi bi-diagram-3"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@activity.Id" method="post"
                                      class="admin-action-form"
                                      onsubmit="return confirm('Delete this activity?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="admin-action-btn admin-action-btn-delete"
                                            title="Delete" aria-label="Delete activity">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No activities found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
