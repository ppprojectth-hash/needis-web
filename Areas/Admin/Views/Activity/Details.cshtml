@model dynamic
@{
    ViewData["Title"] = $"Activity Details";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">@Model.ActivityTitleEN</h5>
                <p class="text-muted mb-3">@Model.ActivityTitleTH</p>
                <div class="mb-2"><code>@Model.ActivitySlug</code></div>
                <p class="text-muted small mb-0">@Model.ShortDescriptionEN</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-3">
                <dl class="row mb-0 small">
                    <dt class="col-5">Author</dt>
                    <dd class="col-7">@(Model.AuthorName ?? "—")</dd>
                    <dt class="col-5">Location</dt>
                    <dd class="col-7">@(Model.LocationEN ?? "—")</dd>
                    <dt class="col-5">Activity Date</dt>
                    <dd class="col-7">@(Model.ActivityDate != null ? ((DateTime)Model.ActivityDate).ToString("dd MMM yyyy") : "—")</dd>
                    <dt class="col-5">Published</dt>
                    <dd class="col-7">@(Model.PublishedDate != null ? ((DateTime)Model.PublishedDate).ToString("dd MMM yyyy") : "—")</dd>
                    <dt class="col-5">Views</dt>
                    <dd class="col-7">@Model.ViewCount</dd>
                    <dt class="col-5">Featured</dt>
                    <dd class="col-7">@((bool)Model.IsFeatured ? "Yes" : "No")</dd>
                    <dt class="col-5">Published</dt>
                    <dd class="col-7">@((bool)Model.IsPublished ? "Yes" : "No")</dd>
                    <dt class="col-5">Active</dt>
                    <dd class="col-7">@((bool)Model.IsActive ? "Yes" : "No")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty((string?)Model.CoverImageUrl) || !string.IsNullOrEmpty((string?)Model.BannerImageUrl))
{
    <div class="row g-3 mt-1">
        @if (!string.IsNullOrEmpty((string?)Model.CoverImageUrl))
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-3">
                        <div class="fw-medium small mb-2">Cover Image</div>
                        <img src="@Model.CoverImageUrl" class="img-fluid rounded" alt="Cover" />
                    </div>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty((string?)Model.BannerImageUrl))
        {
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-3">
                        <div class="fw-medium small mb-2">Banner Image</div>
                        <img src="@Model.BannerImageUrl" class="img-fluid rounded" alt="Banner" />
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">Child Management</h6>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="ManageTags" asp-route-id="@Model.Id" class="btn btn-outline-info">
                        <i class="bi bi-tags me-1"></i>Tags
                        <span class="badge bg-info text-dark ms-1">@Model.TagCount</span>
                    </a>
                    <a asp-controller="ActivityDetailBlock" asp-action="Index" asp-route-activityId="@Model.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-layout-text-window me-1"></i>Detail Blocks
                        <span class="badge bg-secondary ms-1">@Model.BlockCount</span>
                    </a>
                    <a asp-controller="ActivityImage" asp-action="Index" asp-route-activityId="@Model.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-images me-1"></i>Images
                        <span class="badge bg-secondary ms-1">@Model.ImageCount</span>
                    </a>
                    <a asp-controller="ActivityRelatedItem" asp-action="Index" asp-route-activityId="@Model.Id"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-link-45deg me-1"></i>Related
                        <span class="badge bg-secondary ms-1">@Model.RelatedCount</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
