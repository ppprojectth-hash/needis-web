@model Needis.Web.ViewModels.Admin.ProductViewModel
@{
    ViewData["Title"] = "Add Product";
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h5 class="fw-bold mb-0">
                <i class="bi bi-plus-circle me-2" style="color:#2d4199"></i>Add Product
            </h5>
            <p class="text-muted small mb-0 mt-1">Create a new product</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <button type="submit" class="btn btn-sm btn-primary px-3"
                    style="background:#2d4199;border-color:#2d4199">
                <i class="bi bi-save me-1"></i>Create Product
            </button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible d-flex align-items-start gap-2 rounded-3 mb-4">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <div><div asp-validation-summary="ModelOnly"></div></div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        @* ── Left Column ── *@
        <div class="col-lg-8">

            @* A. Product Information *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-info-circle me-2 text-primary"></i>Product Information
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="mb-3">
                        <label asp-for="ProductCategoryId" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.ProductCategoryId) <span class="text-danger">*</span>
                        </label>
                        <select asp-for="ProductCategoryId" asp-items="ViewBag.Categories"
                                class="form-select">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="ProductCategoryId" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="ProductNameEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ProductNameEN) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ProductNameEN" id="ProductNameEN" class="form-control"
                                   placeholder="Product name in English" />
                            <span asp-validation-for="ProductNameEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ProductNameTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ProductNameTH)
                            </label>
                            <input asp-for="ProductNameTH" class="form-control"
                                   placeholder="ชื่อสินค้าภาษาไทย" />
                            <span asp-validation-for="ProductNameTH" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.Slug) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Slug" id="Slug" class="form-control font-monospace"
                               placeholder="auto-generated from product name" />
                        <div class="text-muted small mt-1">URL-safe identifier. Auto-filled from English name.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-4">
                            <label asp-for="Brand" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.Brand)
                            </label>
                            <input asp-for="Brand" class="form-control" placeholder="e.g. Fluke" />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="Model" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.Model)
                            </label>
                            <input asp-for="Model" class="form-control" placeholder="e.g. 87V" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="PartNumber" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.PartNumber)
                            </label>
                            <input asp-for="PartNumber" class="form-control font-monospace"
                                   placeholder="e.g. FL-87V" />
                            <span asp-validation-for="PartNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-0">
                        <div class="col-sm-6">
                            <label asp-for="ShortDescriptionEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ShortDescriptionEN)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "ShortDescriptionEN", Value = Model.ShortDescriptionEN, Rows = 2,
                                Placeholder = "Brief description in English", Language = "en" }' />
                            <span asp-validation-for="ShortDescriptionEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ShortDescriptionTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ShortDescriptionTH)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "ShortDescriptionTH", Value = Model.ShortDescriptionTH, Rows = 2,
                                Placeholder = "คำอธิบายสั้นภาษาไทย", Language = "th" }' />
                            <span asp-validation-for="ShortDescriptionTH" class="text-danger small"></span>
                        </div>
                    </div>

                </div>
            </div>

            @* B. Product Description *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-text-paragraph me-2 text-primary"></i>Product Description
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="DescriptionEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.DescriptionEN)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "DescriptionEN", Value = Model.DescriptionEN, Rows = 5,
                                Placeholder = "Key features...", Language = "en" }' />
                            <span asp-validation-for="DescriptionEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="DescriptionTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.DescriptionTH)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "DescriptionTH", Value = Model.DescriptionTH, Rows = 5,
                                Placeholder = "จุดเด่นสินค้า...", Language = "th" }' />
                            <span asp-validation-for="DescriptionTH" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-0">
                        <div class="col-sm-6">
                            <label asp-for="SpecificationEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.SpecificationEN)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "SpecificationEN", Value = Model.SpecificationEN, Rows = 5,
                                Placeholder = "Technical specifications in English", Language = "en" }' />
                            <span asp-validation-for="SpecificationEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="SpecificationTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.SpecificationTH)
                            </label>
                            <partial name="_RichTextEditor" model='new RichTextEditorFieldViewModel {
                                FieldName = "SpecificationTH", Value = Model.SpecificationTH, Rows = 5,
                                Placeholder = "ข้อมูลจำเพาะทางเทคนิคภาษาไทย", Language = "th" }' />
                            <span asp-validation-for="SpecificationTH" class="text-danger small"></span>
                        </div>
                    </div>

                </div>
            </div>

            @* C. YouTube Video *@
            @if (FF.ProductYoutubeVideoEnabled)
            {
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-youtube me-2" style="color:#ff0000"></i>Product Video / YouTube
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="ShowYoutubeVideo" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="ShowYoutubeVideo" class="form-check-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.ShowYoutubeVideo)
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="YoutubeVideoUrl" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.YoutubeVideoUrl)
                        </label>
                        <input asp-for="YoutubeVideoUrl" class="form-control font-monospace"
                               placeholder="https://www.youtube.com/watch?v=xxxx  or  https://youtu.be/xxxx" />
                        <span asp-validation-for="YoutubeVideoUrl" class="text-danger small d-block mt-1"></span>
                        <div class="text-muted small mt-2">
                            EN: Paste a YouTube link. Supported: youtube.com/watch, youtu.be, embed, or shorts.<br />
                            TH: วางลิงก์ YouTube รองรับรูปแบบ youtube.com/watch, youtu.be, embed หรือ shorts
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="YoutubeVideoTitleEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.YoutubeVideoTitleEN)
                            </label>
                            <input asp-for="YoutubeVideoTitleEN" class="form-control"
                                   placeholder="e.g. Product Demo Video" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="YoutubeVideoTitleTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.YoutubeVideoTitleTH)
                            </label>
                            <input asp-for="YoutubeVideoTitleTH" class="form-control"
                                   placeholder="เช่น วิดีโอสาธิตสินค้า" />
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="YoutubeVideoDescriptionEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.YoutubeVideoDescriptionEN)
                            </label>
                            <textarea asp-for="YoutubeVideoDescriptionEN" class="form-control" rows="2"
                                      placeholder="Short video description in English"></textarea>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="YoutubeVideoDescriptionTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.YoutubeVideoDescriptionTH)
                            </label>
                            <textarea asp-for="YoutubeVideoDescriptionTH" class="form-control" rows="2"
                                      placeholder="คำอธิบายวิดีโอภาษาไทย"></textarea>
                        </div>
                    </div>

                </div>
            </div>
            } @* end ProductYoutubeVideoEnabled *@

        </div>

        @* ── Right Column ── *@
        <div class="col-lg-4">

            @* C. Media Files *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-images me-2 text-primary"></i>Media Files
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="mb-4">
                        <label class="form-label small fw-semibold">Product Image</label>
                        <div id="productImagePreviewWrap" class="admin-upload-preview-frame mb-2 d-none">
                            <img id="productImagePreview" src="#" alt="Preview" class="admin-image-preview" />
                        </div>
                        <input asp-for="MainImageFile" type="file" class="form-control js-image-preview-input"
                               accept=".jpg,.jpeg,.png,.webp" id="ImageFileInput"
                               data-preview-target="#productImagePreview"
                               data-preview-wrapper="#productImagePreviewWrap"
                               data-size-target="#productImgSize" />
                        <span id="productImgSize" class="upload-file-meta"></span>
                        <span asp-validation-for="MainImageFile" class="text-danger small d-block mt-1"></span>
                        <div class="text-muted small mt-2">
                            Recommended: <strong>1200 × 900 px</strong> with white/transparent background<br />
                            JPG, PNG, WebP &nbsp;·&nbsp; Max 5 MB
                        </div>
                    </div>

                    <div>
                        <label class="form-label small fw-semibold">Brochure (PDF)</label>
                        <input asp-for="BrochureFile" type="file" class="form-control js-file-meta-input"
                               accept=".pdf" id="BrochureFileInput"
                               data-size-target="#productPdfSize" />
                        <span id="productPdfSize" class="upload-file-meta"></span>
                        <span asp-validation-for="BrochureFile" class="text-danger small d-block mt-1"></span>
                        <div class="text-muted small mt-2">PDF only &nbsp;·&nbsp; Max 20 MB</div>
                    </div>

                </div>
            </div>

            @* D. Price and Display Settings *@
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-sliders me-2 text-primary"></i>Price & Display
                    </h6>
                </div>
                <div class="card-body px-4 pb-4 pt-3">

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.Price)
                        </label>
                        <input asp-for="Price" type="number" class="form-control"
                               step="0.01" min="0" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsPriceVisible" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsPriceVisible" class="form-check-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.IsPriceVisible)
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DisplayOrder" class="form-label small fw-semibold">
                            @Html.DisplayNameFor(m => m.DisplayOrder)
                        </label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="0" max="9999" />
                        <div class="text-muted small mt-1">Lower numbers appear first.</div>
                        <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                    </div>

                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsFeatured" class="form-check-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.IsFeatured)
                                <span class="text-muted fw-normal">(สินค้าแนะนำ)</span>
                            </label>
                        </div>
                    </div>

                    <div class="mb-2">
                        <div class="form-check form-switch">
                            <input asp-for="IsPromotion" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsPromotion" class="form-check-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.IsPromotion)
                                <span class="text-muted fw-normal">(โปรโมชั่น)</span>
                            </label>
                        </div>
                    </div>

                    <div class="text-muted small mb-3">
                        EN: Hot Product and Promotion tags will be shown on product cards and the home page.<br />
                        TH: ระบบจะแสดงป้ายสินค้าแนะนำและโปรโมชั่นบนการ์ดสินค้าและหน้า Home
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="PromotionLabelEN" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.PromotionLabelEN)
                            </label>
                            <textarea asp-for="PromotionLabelEN" class="form-control" rows="2" maxlength="200"
                                      placeholder="e.g. Buy 1 Get 1, Special discount, Limited time offer"></textarea>
                            <span asp-validation-for="PromotionLabelEN" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="PromotionLabelTH" class="form-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.PromotionLabelTH)
                            </label>
                            <textarea asp-for="PromotionLabelTH" class="form-control" rows="2" maxlength="200"
                                      placeholder="เช่น ซื้อ 1 แถม 1, ส่วนลดพิเศษ, โปรโมชั่นจำกัดเวลา"></textarea>
                            <span asp-validation-for="PromotionLabelTH" class="text-danger small"></span>
                        </div>
                        <div class="col-12 text-muted small">
                            EN: Leave blank to use the default "Promotion" badge text.<br />
                            TH: เว้นว่างไว้เพื่อใช้ข้อความป้ายเริ่มต้น "โปรโมชั่น"
                        </div>
                    </div>

                    <div class="mb-0">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label small fw-semibold">
                                @Html.DisplayNameFor(m => m.IsActive)
                            </label>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
<script>
    // Auto-generate slug from English name
    const nameInput = document.getElementById('ProductNameEN');
    const slugInput = document.getElementById('Slug');
    let slugEdited = false;

    slugInput.addEventListener('input', () => { slugEdited = true; });

    nameInput?.addEventListener('input', function () {
        if (slugEdited) return;
        let val = this.value.trim().toLowerCase()
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9\-]/g, '')
            .replace(/-{2,}/g, '-')
            .replace(/^-+|-+$/g, '');
        slugInput.value = val;
    });
</script>
}
