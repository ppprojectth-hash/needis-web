@model IEnumerable<Needis.Web.ViewModels.Admin.ProductListItem>
@{
    ViewData["Title"] = "Products";
    var keyword    = ViewBag.SearchKeyword as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
}

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 rounded-3 mb-4">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>@successMsg</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] is string warnMsg)
{
    <div class="alert alert-warning alert-dismissible d-flex align-items-center gap-2 rounded-3 mb-4">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span>@warnMsg</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h5 class="fw-bold mb-0">
            <i class="bi bi-box-seam me-2" style="color:#2d4199"></i>Products
        </h5>
        <p class="text-muted small mb-0 mt-1">Manage your product catalogue</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <select name="categoryId" class="form-select form-select-sm" style="width:180px"
                    onchange="this.form.submit()">
                <option value="">All Categories</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.CategoryFilter)
                {
                    <option value="@item.Value" selected="@(item.Selected)">@item.Text</option>
                }
            </select>
            <input type="text" name="q" value="@keyword" class="form-control form-control-sm"
                   placeholder="Search…" style="width:190px" />
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(keyword) || categoryId.HasValue)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>
        <a asp-action="Create" class="btn btn-sm btn-primary px-3"
           style="background:#2d4199;border-color:#2d4199">
            <i class="bi bi-plus-lg me-1"></i>Add Product
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    @if (!Model.Any())
    {
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-box-seam fs-1 d-block mb-3" style="color:#c5cde8"></i>
            @if (!string.IsNullOrEmpty(keyword) || categoryId.HasValue)
            {
                <p class="mb-2">No products match your search.</p>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear filters</a>
            }
            else
            {
                <p class="mb-2">No products yet.</p>
                <a asp-action="Create" class="btn btn-sm btn-primary"
                   style="background:#2d4199;border-color:#2d4199">
                    <i class="bi bi-plus-lg me-1"></i>Add First Product
                </a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8f9fc">
                    <tr class="text-muted small fw-semibold"
                        style="font-size:.8rem;text-transform:uppercase;letter-spacing:.04em">
                        <th class="ps-4 py-3" style="width:72px">Image</th>
                        <th class="py-3">Product Name</th>
                        <th class="py-3" style="width:150px">Category</th>
                        <th class="py-3" style="width:160px">Brand / Model</th>
                        <th class="py-3" style="width:120px">Part No.</th>
                        <th class="py-3 text-end" style="width:110px">Price</th>
                        <th class="py-3 text-center" style="width:75px">Featured</th>
                        <th class="py-3 text-center" style="width:80px">Order</th>
                        <th class="py-3 text-center" style="width:90px">Status</th>
                        <th class="py-3 text-end pe-4" style="width:110px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-2">
                                @if (!string.IsNullOrEmpty(item.MainImagePath))
                                {
                                    <img src="@item.MainImagePath" alt="@item.NameEN"
                                         class="rounded-2"
                                         style="width:56px;height:56px;object-fit:cover;border:1px solid #eee" />
                                }
                                else
                                {
                                    <div class="rounded-2 d-flex align-items-center justify-content-center bg-light"
                                         style="width:56px;height:56px;color:#aaa">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="py-2">
                                <div class="fw-semibold small">@item.NameEN</div>
                                @if (!string.IsNullOrEmpty(item.NameTH))
                                {
                                    <div class="text-muted small">@item.NameTH</div>
                                }
                            </td>
                            <td class="py-2 small text-muted">@item.CategoryNameEN</td>
                            <td class="py-2 small">
                                @if (!string.IsNullOrEmpty(item.Brand))
                                {
                                    <div class="fw-semibold">@item.Brand</div>
                                }
                                @if (!string.IsNullOrEmpty(item.Model))
                                {
                                    <div class="text-muted">@item.Model</div>
                                }
                            </td>
                            <td class="py-2 small">
                                <code class="text-secondary">@(item.Sku ?? "—")</code>
                            </td>
                            <td class="py-2 small text-end">
                                @if (item.IsPriceVisible && item.Price.HasValue)
                                {
                                    <span>@item.Price.Value.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="py-2 text-center">
                                @if (item.IsFeatured)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-muted"></i>
                                }
                            </td>
                            <td class="py-2 text-center">
                                <span class="badge rounded-pill bg-light text-dark border fw-normal">
                                    @item.DisplayOrder
                                </span>
                            </td>
                            <td class="py-2 text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill text-bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill text-bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="py-2 text-end pe-4">
                                <a asp-area="Admin" asp-controller="ProductSpecification" asp-action="Index"
                                   asp-route-productId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary me-1"
                                   title="Manage Specifications">
                                    <i class="bi bi-list-check"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete this product? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
