@model Needis.Web.ViewModels.Admin.ProductSpecificationViewModel
@{
    ViewData["Title"] = $"Edit Specification — {Model.SpecNameEN}";
    Layout = "_AdminLayout";
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProductId" />
    <input type="hidden" asp-for="Id" />

    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h5 class="fw-bold mb-0">
                <i class="bi bi-pencil-square me-2" style="color:#2d4199"></i>Edit Specification
            </h5>
            <p class="text-muted small mb-0 mt-1">@Model.ProductNameEN · @Model.SpecNameEN</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-route-productId="@Model.ProductId"
               class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <button type="submit" class="btn btn-sm btn-primary px-3"
                    style="background:#2d4199;border-color:#2d4199">
                <i class="bi bi-save me-1"></i>Save Changes
            </button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger rounded-3 mb-4">
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">

            @* A. Group *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-folder me-2 text-primary"></i>Specification Group
                    </h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Group (TH)</label>
                            <input asp-for="SpecGroupTH" class="form-control" />
                            <span asp-validation-for="SpecGroupTH" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Group (EN)</label>
                            <input asp-for="SpecGroupEN" class="form-control" />
                            <span asp-validation-for="SpecGroupEN" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* B. Spec Name + Value *@
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-input-cursor-text me-2 text-primary"></i>Specification Detail
                    </h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Spec Name (TH)</label>
                            <input asp-for="SpecNameTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">
                                Spec Name (EN) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="SpecNameEN" class="form-control" />
                            <span asp-validation-for="SpecNameEN" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Value (TH)</label>
                            <input asp-for="SpecValueTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Value (EN)</label>
                            <input asp-for="SpecValueEN" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Unit (TH)</label>
                            <input asp-for="UnitTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Unit (EN)</label>
                            <input asp-for="UnitEN" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Remark (TH)</label>
                            <input asp-for="RemarkTH" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Remark (EN)</label>
                            <input asp-for="RemarkEN" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-sliders me-2 text-primary"></i>Display Settings
                    </h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" min="0" />
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsHighlight" class="form-check-input" role="switch" />
                        <label asp-for="IsHighlight" class="form-check-label small">
                            Highlight <span class="text-muted">(key spec)</span>
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label small">Active</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
