@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Needis Admin — Sign In</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(145deg, #111e5c 0%, #2d4199 60%, #1a2462 100%);
        }
        .login-wrapper { width: 100%; max-width: 400px; padding: 1rem; }
        .login-card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 24px 64px rgba(0, 0, 0, .35);
        }
        .login-header {
            text-align: center;
            padding: 2rem 2rem 1rem;
        }
        .login-logo {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 52px; height: 52px;
            background: #2d4199;
            border-radius: 12px;
            margin-bottom: .9rem;
        }
        .login-logo svg { width: 28px; height: 28px; fill: #fff; }
        .login-title { font-size: 1.25rem; font-weight: 700; color: #1a2462; margin-bottom: .2rem; }
        .login-sub   { font-size: .82rem; color: #8896b0; }
        .login-body  { padding: 1.25rem 2rem 2rem; }
        .form-label  { font-size: .82rem; font-weight: 600; color: #4a5568; margin-bottom: .3rem; }
        .form-control {
            border-radius: 8px;
            border: 1.5px solid #dde3f0;
            font-size: .9rem;
            padding: .55rem .85rem;
        }
        .form-control:focus { border-color: #2d4199; box-shadow: 0 0 0 3px rgba(45,65,153,.15); }
        .btn-login {
            background: #2d4199;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: .02em;
            padding: .6rem;
            transition: background .2s;
        }
        .btn-login:hover { background: #1e2f7a; }
        .form-check-input:checked { background-color: #2d4199; border-color: #2d4199; }
        .error-summary { border-radius: 8px; font-size: .85rem; }
    </style>
</head>
<body>
<div class="login-wrapper">
    <div class="card login-card">
        <div class="login-header">
            <div class="login-logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
            </div>
            <div class="login-title">Needis Admin</div>
            <div class="login-sub">Back Office Management System</div>
        </div>

        <div class="login-body">
            <form asp-action="Login" asp-controller="Account" asp-area="Admin" method="post" novalidate>
                <input type="hidden" asp-for="ReturnUrl" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger error-summary py-2 px-3 mb-3">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="UsernameOrEmail" class="form-label">Username or Email</label>
                    <input asp-for="UsernameOrEmail" class="form-control"
                           placeholder="Enter username or email" autofocus autocomplete="username" />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="password"
                           placeholder="Enter password" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label" style="font-size:.85rem">
                            Keep me signed in
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-login btn-primary w-100">Sign In</button>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
