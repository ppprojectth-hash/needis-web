@model Needis.Web.ViewModels.Quotation.QuotationCartViewModel
@{
    var lang = Model.CurrentLanguage;
    string L(string? th, string? en) => lang == "th" ? (th ?? en ?? "") : (en ?? th ?? "");

    ViewData["Title"] = lang == "th" ? "รายการขอใบเสนอราคา" : "Quotation Cart";
}

@* ── Page Header ─────────────────────────────────────────────────────────── *@
<div class="product-page-header">
    <div class="container py-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-white-50">
                        @(lang == "th" ? "หน้าหลัก" : "Home")
                    </a>
                </li>
                <li class="breadcrumb-item active text-white">
                    @(lang == "th" ? "รายการขอใบเสนอราคา" : "Quotation Cart")
                </li>
            </ol>
        </nav>
        <h1 class="text-white fw-bold mb-0" style="font-size:clamp(1.4rem,3vw,2rem)">
            <i class="bi bi-cart3 me-2"></i>
            @(lang == "th" ? "รายการขอใบเสนอราคา" : "Quotation Cart")
        </h1>
        @if (Model.TotalItems > 0)
        {
            <p class="text-white-50 mb-0 mt-1" style="font-size:.9rem">
                @(lang == "th" ? $"{Model.TotalItems} รายการ" : $"{Model.TotalItems} item(s)")
            </p>
        }
    </div>
</div>

<div class="container py-5">

    @* Alerts *@
    @if (TempData["CartSuccess"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["CartError"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        @* ── Empty State ── *@
        <div class="text-center py-5 reveal">
            <div class="mb-4">
                <i class="bi bi-cart-x" style="font-size:4rem;color:#c7d0e8"></i>
            </div>
            <h3 class="fw-bold mb-2" style="color:var(--needis-dark)">
                @(lang == "th" ? "ยังไม่มีรายการขอใบเสนอราคา" : "Your quotation cart is empty")
            </h3>
            <p class="text-muted mb-4">
                @(lang == "th"
                    ? "เพิ่มสินค้าหรือบริการที่คุณต้องการเพื่อส่งคำขอใบเสนอราคา"
                    : "Add products or services you're interested in to send a quotation request.")
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Product" asp-action="Index"
                   class="btn btn-primary px-4" style="background:var(--needis-primary);border-color:var(--needis-primary)">
                    <i class="bi bi-box-seam me-2"></i>
                    @(lang == "th" ? "ดูสินค้า" : "View Products")
                </a>
                <a asp-controller="Services" asp-action="Index"
                   class="btn btn-outline-primary px-4" style="color:var(--needis-primary);border-color:var(--needis-primary)">
                    <i class="bi bi-tools me-2"></i>
                    @(lang == "th" ? "ดูบริการ" : "View Services")
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">

            @* ── Left: Cart Items ── *@
            <div class="col-lg-7 reveal">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold mb-0" style="color:var(--needis-dark)">
                        <i class="bi bi-list-ul me-2"></i>
                        @(lang == "th" ? "รายการที่เลือก" : "Selected Items")
                    </h5>
                    <form asp-action="Clear" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('@(lang == "th" ? "ต้องการล้างรายการทั้งหมด?" : "Clear all items?")')">
                            <i class="bi bi-trash3 me-1"></i>
                            @(lang == "th" ? "ล้างรายการ" : "Clear Cart")
                        </button>
                    </form>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model.Items)
                    {
                        var itemName   = item.ItemType == "Product"
                            ? L(item.ProductNameSnapshotTH, item.ProductNameSnapshotEN)
                            : L(item.ServiceNameSnapshotTH, item.ServiceNameSnapshotEN);
                        var itemDetail = item.ItemType == "Product"
                            ? string.Join(" · ", new[] { item.BrandSnapshot, item.ModelSnapshot }
                                .Where(x => !string.IsNullOrEmpty(x)))
                            : item.ServiceCodeSnapshot ?? "";

                        <div class="card border-0 shadow-sm rounded-3">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="flex-shrink-0 pt-1">
                                        @if (item.ItemType == "Product")
                                        {
                                            <span class="badge" style="background:var(--needis-primary)">
                                                <i class="bi bi-box-seam me-1"></i>
                                                @(lang == "th" ? "สินค้า" : "Product")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-purple" style="background:#6f42c1">
                                                <i class="bi bi-tools me-1"></i>
                                                @(lang == "th" ? "บริการ" : "Service")
                                            </span>
                                        }
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-semibold text-truncate" style="color:var(--needis-dark)">@itemName</div>
                                        @if (!string.IsNullOrEmpty(itemDetail))
                                        {
                                            <div class="small text-muted font-monospace">@itemDetail</div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.PartNumberSnapshot))
                                        {
                                            <div class="small text-muted">
                                                @(lang == "th" ? "รหัส:" : "Part No:") <code>@item.PartNumberSnapshot</code>
                                            </div>
                                        }

                                        @* Update quantity *@
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2 mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <label class="small text-muted mb-0">@(lang == "th" ? "จำนวน:" : "Qty:")</label>
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="999"
                                                   class="form-control form-control-sm" style="width:70px" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-check2"></i>
                                            </button>
                                        </form>

                                        @* Update note *@
                                        <form asp-action="UpdateNote" method="post" class="d-flex align-items-start gap-2 mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <input type="text" name="itemNote" value="@item.ItemNote"
                                                   class="form-control form-control-sm"
                                                   placeholder="@(lang == "th" ? "หมายเหตุ..." : "Note...")" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <div class="flex-shrink-0">
                                        <form asp-action="RemoveItem" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="@(lang == "th" ? "ลบ" : "Remove")">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 d-flex gap-3 flex-wrap">
                    <a asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-primary" style="color:var(--needis-primary);border-color:var(--needis-primary)">
                        <i class="bi bi-plus-circle me-1"></i>
                        @(lang == "th" ? "เพิ่มสินค้า" : "Add More Products")
                    </a>
                    <a asp-controller="Services" asp-action="Index"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-plus-circle me-1"></i>
                        @(lang == "th" ? "เพิ่มบริการ" : "Add More Services")
                    </a>
                </div>
            </div>

            @* ── Right: Submit Form ── *@
            <div class="col-lg-5 reveal reveal-delay-1">
                <div class="card border-0 shadow-sm rounded-3 sticky-lg-top" style="top:90px">
                    <div class="card-header border-0 pt-4 pb-2 px-4" style="background:transparent">
                        <h5 class="fw-bold mb-0" style="color:var(--needis-dark)">
                            <i class="bi bi-person-lines-fill me-2"></i>
                            @(lang == "th" ? "ข้อมูลผู้ติดต่อ" : "Contact Information")
                        </h5>
                        <p class="text-muted small mb-0 mt-1">
                            @(lang == "th"
                                ? "กรอกข้อมูลเพื่อส่งคำขอใบเสนอราคา"
                                : "Fill in your details to submit the quotation request.")
                        </p>
                    </div>
                    <div class="card-body px-4 pb-4">

                        <form asp-action="Submit" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "ชื่อ-นามสกุล" : "Full Name")
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="CustomerName" class="form-control"
                                       placeholder="@(lang == "th" ? "ชื่อ-นามสกุล" : "Your full name")" />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "บริษัท/องค์กร" : "Company / Organization")
                                </label>
                                <input asp-for="CompanyName" class="form-control"
                                       placeholder="@(lang == "th" ? "ชื่อบริษัท" : "Company name")" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "อีเมล" : "Email")
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Email" type="email" class="form-control"
                                       placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "เบอร์โทรศัพท์" : "Phone")
                                </label>
                                <input asp-for="Phone" type="tel" class="form-control"
                                       placeholder="@(lang == "th" ? "เบอร์โทรศัพท์" : "Phone number")" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "วิธีติดต่อที่ต้องการ" : "Preferred Contact Method")
                                </label>
                                <select asp-for="PreferredContactMethod" class="form-select">
                                    <option value="">@(lang == "th" ? "-- เลือก --" : "-- Select --")</option>
                                    <option value="Email">Email</option>
                                    <option value="Phone">Phone</option>
                                    <option value="Line">Line</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "หัวข้อ" : "Subject")
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Subject" class="form-control"
                                       placeholder="@(lang == "th" ? "หัวข้อคำขอ" : "Request subject")" />
                                <span asp-validation-for="Subject" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-semibold">
                                    @(lang == "th" ? "ข้อความเพิ่มเติม" : "Additional Message")
                                </label>
                                <textarea asp-for="Message" class="form-control" rows="3"
                                          placeholder="@(lang == "th" ? "รายละเอียดเพิ่มเติม..." : "Additional details...")"></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-lg fw-semibold text-white"
                                        style="background:var(--needis-primary);border-color:var(--needis-primary)">
                                    <i class="bi bi-send me-2"></i>
                                    @(lang == "th" ? "ส่งคำขอใบเสนอราคา" : "Submit Quotation Request")
                                </button>
                            </div>

                            <p class="text-muted text-center small mt-3 mb-0">
                                <i class="bi bi-shield-check me-1"></i>
                                @(lang == "th"
                                    ? "ข้อมูลของคุณปลอดภัยและเป็นความลับ"
                                    : "Your information is safe and confidential.")
                            </p>
                        </form>

                    </div>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
