@model Needis.Web.Models.SiteSetting?
@{
    var lang        = (string)(ViewData["CurrentLanguage"] ?? "en");
    var currentPath = (string)(ViewData["CurrentPath"] ?? "/");
    var returnUrl   = (string)(ViewData["ReturnUrl"]    ?? "/");
    var companyEN   = Model?.CompanyNameEN ?? "Needis";
    var companyTH   = Model?.CompanyNameTH ?? companyEN;
    var companyName = lang == "th" ? companyTH : companyEN;
}

<nav class="navbar navbar-expand-lg site-navbar sticky-top">
    <div class="container">

        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            @if (!string.IsNullOrEmpty(Model?.LogoPath))
            {
                <img src="@Model.LogoPath" alt="@companyName" class="site-logo" />
            }
            else
            {
                <span class="fw-bold fs-5 text-white">@companyEN</span>
            }
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-4">
                <li class="nav-item">
                    <a class="nav-link @(currentPath == "/" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        @(lang == "th" ? "หน้าหลัก" : "Home")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/About") ? "active" : "")"
                       asp-controller="About" asp-action="Index">
                        @(lang == "th" ? "เกี่ยวกับเรา" : "About")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Product") ? "active" : "")"
                       asp-controller="Product" asp-action="Index">
                        @(lang == "th" ? "สินค้า" : "Products")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Services") ? "active" : "")"
                       asp-controller="Services" asp-action="Index">
                        @(lang == "th" ? "บริการ" : "Services")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Activity") ? "active" : "")"
                       asp-controller="Activity" asp-action="Index">
                        @(lang == "th" ? "กิจกรรม" : "Activity")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Contact") ? "active" : "")"
                       asp-controller="Contact" asp-action="Index">
                        @(lang == "th" ? "ติดต่อ" : "Contact")
                    </a>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                <div class="position-relative">
                    @await Component.InvokeAsync("QuotationCartBadge")
                </div>
                <div class="lang-switcher d-flex align-items-center gap-1">
                    <a asp-controller="Language" asp-action="Change"
                       asp-route-lang="en" asp-route-returnUrl="@returnUrl"
                       class="@(lang == "en" ? "active" : "")">EN</a>
                    <span class="text-white-50">|</span>
                    <a asp-controller="Language" asp-action="Change"
                       asp-route-lang="th" asp-route-returnUrl="@returnUrl"
                       class="@(lang == "th" ? "active" : "")">TH</a>
                </div>
                <a asp-controller="Quotation" asp-action="Create"
                   class="btn btn-sm btn-light fw-semibold d-none d-lg-inline-flex align-items-center gap-1"
                   style="color:#2d4199">
                    <i class="bi bi-file-earmark-text"></i>
                    @(lang == "th" ? "ขอใบเสนอราคา" : "Request Quote")
                </a>
            </div>
        </div>

    </div>
</nav>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
