@model QuotationRequestFormViewModel
@{
    var lang    = Model.CurrentLanguage;
    var product = Model.Product;
    var svc     = Model.Service;
    string L(string? th, string? en) => lang == "th" ? (th ?? en ?? "") : (en ?? th ?? "");

    ViewData["Title"] = lang == "th" ? "ขอใบเสนอราคา" : "Request Quotation";
}

@* ── Page Header ─────────────────────────────────────────────────────────── *@
<section class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-dark mb-2">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index">@(lang == "th" ? "หน้าหลัก" : "Home")</a>
                </li>
                @if (product != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Product" asp-action="Detail" asp-route-slug="@product.Slug">
                            @L(product.NameTH, product.NameEN)
                        </a>
                    </li>
                }
                @if (svc != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Services" asp-action="Detail" asp-route-slug="@svc.ServiceSlug">
                            @L(svc.ServiceNameTH, svc.ServiceNameEN)
                        </a>
                    </li>
                }
                <li class="breadcrumb-item active">@(lang == "th" ? "ขอใบเสนอราคา" : "Request Quotation")</li>
            </ol>
        </nav>
        <h1 class="page-header-title">@(lang == "th" ? "ขอใบเสนอราคา" : "Request Quotation")</h1>
        <p class="page-header-subtitle">
            @(lang == "th"
                ? "กรอกข้อมูลด้านล่าง ทีมงานของเราจะติดต่อกลับโดยเร็ว"
                : "Fill in the form below and our team will get back to you promptly.")
        </p>
    </div>
</section>

@* ── Main Content ─────────────────────────────────────────────────────────── *@
<section class="py-5">
    <div class="container">
        <div class="row g-5 justify-content-center">

            @* ── Left: Summary Card ── *@
            <div class="col-lg-4">
                @if (product != null)
                {
                    @* Product Summary *@
                    var catName  = L(product.Category?.NameTH, product.Category?.NameEN);
                    var prodName = L(product.NameTH, product.NameEN);

                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        @if (!string.IsNullOrEmpty(product.MainImagePath))
                        {
                            <img src="@product.MainImagePath" alt="@prodName"
                                 class="card-img-top rounded-top-3"
                                 style="height:200px;object-fit:contain;background:#f8f9fc;padding:16px" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center rounded-top-3"
                                 style="height:160px;background:linear-gradient(135deg,#e8ecf8 0%,#c5cde8 100%)">
                                <i class="bi bi-box-seam fs-1 text-muted"></i>
                            </div>
                        }
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(catName))
                            {
                                <span class="badge product-cat-badge mb-2">@catName</span>
                            }
                            <h6 class="fw-bold mb-1" style="color:var(--needis-dark)">@prodName</h6>
                            @if (!string.IsNullOrEmpty(product.Brand) || !string.IsNullOrEmpty(product.Model))
                            {
                                <p class="small text-muted mb-1">
                                    @product.Brand@(!string.IsNullOrEmpty(product.Brand) && !string.IsNullOrEmpty(product.Model) ? " · " : "")@product.Model
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(product.Sku))
                            {
                                <p class="small text-muted mb-0">
                                    @(lang == "th" ? "รหัส: " : "Part No: ")<code>@product.Sku</code>
                                </p>
                            }
                        </div>
                    </div>
                }
                else if (svc != null)
                {
                    @* Service Summary *@
                    var svcName = L(svc.ServiceNameTH, svc.ServiceNameEN);
                    var svcDesc = L(svc.ShortDescriptionTH, svc.ShortDescriptionEN);

                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        @if (!string.IsNullOrEmpty(svc.CoverImageUrl))
                        {
                            <img src="@svc.CoverImageUrl" alt="@svcName"
                                 class="card-img-top rounded-top-3"
                                 style="height:180px;object-fit:cover" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center rounded-top-3"
                                 style="height:140px;background:linear-gradient(135deg,#e8ecf8 0%,#c5cde8 100%)">
                                @if (!string.IsNullOrEmpty(svc.IconUrl))
                                {
                                    <i class="@svc.IconUrl fs-1 text-muted"></i>
                                }
                                else
                                {
                                    <i class="bi bi-tools fs-1 text-muted"></i>
                                }
                            </div>
                        }
                        <div class="card-body">
                            <span class="badge mb-2" style="background:#6f42c1;font-size:.72rem">
                                @(lang == "th" ? "บริการ" : "Service")
                            </span>
                            <h6 class="fw-bold mb-1" style="color:var(--needis-dark)">@svcName</h6>
                            @if (!string.IsNullOrEmpty(svc.ServiceCode))
                            {
                                <p class="small text-muted mb-1">
                                    @(lang == "th" ? "รหัสบริการ: " : "Code: ")<code>@svc.ServiceCode</code>
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(svcDesc))
                            {
                                <p class="small text-muted mb-0">
                                    @(svcDesc.Length > 100 ? svcDesc[..100] + "…" : svcDesc)
                                </p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @* General request *@
                    <div class="card border-0 shadow-sm rounded-3 mb-4 p-4 text-center">
                        <div class="mb-3" style="font-size:3rem;color:#c5cde8">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <h6 class="fw-bold" style="color:var(--needis-primary)">
                            @(lang == "th" ? "คำขอใบเสนอราคาทั่วไป" : "General Quotation Request")
                        </h6>
                        <p class="small text-muted mb-0">
                            @(lang == "th"
                                ? "แจ้งรายละเอียดสินค้าหรือบริการที่ต้องการในข้อความด้านล่าง"
                                : "Please describe the products or services you need in the message field.")
                        </p>
                    </div>
                }

                <div class="card border-0 shadow-sm rounded-3 p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--needis-primary)">
                        <i class="bi bi-info-circle me-2"></i>
                        @(lang == "th" ? "ข้อมูลการติดต่อ" : "Contact Information")
                    </h6>
                    <p class="small text-muted mb-0 lh-lg">
                        @(lang == "th"
                            ? "เราจะตอบกลับภายใน 24 ชั่วโมงในวันทำการ คุณสามารถเลือกวิธีการติดต่อที่สะดวกในฟอร์ม"
                            : "We respond within 24 business hours. You can choose your preferred contact method in the form.")
                    </p>
                </div>
            </div>

            @* ── Right: Form ── *@
            <div class="col-lg-8">
                <div class="contact-form-card">
                    <h4 class="fw-bold mb-1">
                        @(lang == "th" ? "รายละเอียดคำขอ" : "Quotation Details")
                    </h4>
                    <p class="text-muted mb-4 small">
                        @(lang == "th" ? "ช่องที่มี * จำเป็นต้องกรอก" : "Fields marked with * are required.")
                    </p>

                    <form asp-controller="Quotation" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        @* Hidden context fields *@
                        @if (product != null)
                        {
                            <input type="hidden" asp-for="ProductId" />
                            <input type="hidden" asp-for="ProductSlug" />
                        }
                        @if (svc != null)
                        {
                            <input type="hidden" asp-for="ServiceId" />
                            <input type="hidden" asp-for="ServiceSlug" />
                        }
                        <input type="hidden" asp-for="RequestType" />

                        @* Customer Info *@
                        <h6 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            @(lang == "th" ? "ข้อมูลผู้ติดต่อ" : "Contact Details")
                        </h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label fw-medium">
                                    @(lang == "th" ? "ชื่อ-นามสกุล" : "Full Name") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="CustomerName" class="form-control"
                                       placeholder="@(lang == "th" ? "ชื่อ-นามสกุล" : "Your full name")" />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CompanyName" class="form-label fw-medium">
                                    @(lang == "th" ? "ชื่อบริษัท / องค์กร" : "Company / Organization")
                                </label>
                                <input asp-for="CompanyName" class="form-control"
                                       placeholder="@(lang == "th" ? "ชื่อบริษัท (ถ้ามี)" : "Company name (optional)")" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-medium">
                                    @(lang == "th" ? "อีเมล" : "Email Address") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Email" type="email" class="form-control"
                                       placeholder="@(lang == "th" ? "อีเมลของคุณ" : "your@email.com")" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-medium">
                                    @(lang == "th" ? "เบอร์โทรศัพท์" : "Phone Number")
                                </label>
                                <input asp-for="Phone" class="form-control"
                                       placeholder="@(lang == "th" ? "เบอร์โทร (ไม่บังคับ)" : "Optional")" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PreferredContactMethod" class="form-label fw-medium">
                                    @(lang == "th" ? "วิธีการติดต่อที่ต้องการ" : "Preferred Contact Method")
                                </label>
                                <select asp-for="PreferredContactMethod" class="form-select">
                                    <option value="">@(lang == "th" ? "-- เลือก --" : "-- Select --")</option>
                                    <option value="Email">Email</option>
                                    <option value="Phone">@(lang == "th" ? "โทรศัพท์" : "Phone")</option>
                                    <option value="Line">Line</option>
                                </select>
                            </div>
                        </div>

                        @* Request Info *@
                        <h6 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            @if (product != null)
                            {
                                @(lang == "th" ? "รายละเอียดสินค้าที่ต้องการ" : "Product Request Details")
                            }
                            else if (svc != null)
                            {
                                @(lang == "th" ? "รายละเอียดบริการที่ต้องการ" : "Service Request Details")
                            }
                            else
                            {
                                @(lang == "th" ? "รายละเอียดคำขอ" : "Request Details")
                            }
                        </h6>
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Subject" class="form-label fw-medium">
                                    @(lang == "th" ? "หัวข้อ" : "Subject") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Subject" class="form-control"
                                       placeholder="@(lang == "th" ? "หัวข้อคำขอ" : "Quotation subject")" />
                                <span asp-validation-for="Subject" class="text-danger small"></span>
                            </div>
                            @if (product != null || svc != null)
                            {
                                <div class="col-md-4">
                                    <label asp-for="Quantity" class="form-label fw-medium">
                                        @(lang == "th" ? "จำนวน" : "Quantity") <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Quantity" type="number" min="1" max="9999" class="form-control" />
                                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                                </div>
                                <div class="col-md-8">
                                    <label asp-for="ItemNote" class="form-label fw-medium">
                                        @(lang == "th" ? "หมายเหตุ" : "Note")
                                    </label>
                                    <input asp-for="ItemNote" class="form-control"
                                           placeholder="@(lang == "th" ? "ข้อกำหนดพิเศษ หรือรายละเอียดเพิ่มเติม" : "Special requirements or additional details")" />
                                </div>
                            }
                            <div class="col-12">
                                <label asp-for="Message" class="form-label fw-medium">
                                    @(lang == "th" ? "ข้อความเพิ่มเติม" : "Additional Message")
                                </label>
                                <textarea asp-for="Message" class="form-control" rows="5"
                                          placeholder="@(lang == "th" ? "รายละเอียดเพิ่มเติม หรือสินค้า/บริการที่ต้องการ" : "Additional details or describe what you need...")"></textarea>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg px-5"
                                style="background:var(--needis-primary);border-color:var(--needis-primary)">
                            <i class="bi bi-send-fill me-2"></i>
                            @(lang == "th" ? "ส่งคำขอใบเสนอราคา" : "Submit Quotation Request")
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
