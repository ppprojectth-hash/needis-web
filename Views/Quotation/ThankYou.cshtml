@{
    var lang       = ViewData["CurrentLanguage"] as string ?? "en";
    var requestNo  = ViewData["RequestNo"] as string ?? "";
    ViewData["Title"] = lang == "th" ? "ส่งคำขอเรียบร้อย" : "Request Submitted";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">

                <div class="mb-4" style="font-size:5rem;color:var(--needis-primary)">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <h1 class="fw-bold mb-2" style="color:var(--needis-dark)">
                    @(lang == "th" ? "ส่งคำขอเรียบร้อยแล้ว!" : "Request Submitted!")
                </h1>
                <p class="text-muted mb-4 lh-lg">
                    @(lang == "th"
                        ? "ขอบคุณสำหรับคำขอใบเสนอราคา ทีมงานของเราจะตรวจสอบและติดต่อกลับโดยเร็วที่สุด"
                        : "Thank you for your quotation request. Our team will review it and contact you as soon as possible.")
                </p>

                @if (!string.IsNullOrEmpty(requestNo))
                {
                    <div class="alert alert-light border shadow-sm d-inline-block px-5 py-3 mb-4 rounded-3">
                        <div class="small text-muted mb-1">
                            @(lang == "th" ? "หมายเลขคำขอของคุณ" : "Your Request Number")
                        </div>
                        <div class="fw-bold fs-5" style="color:var(--needis-primary);letter-spacing:.05em">
                            @requestNo
                        </div>
                    </div>
                }

                <p class="text-muted small mb-5">
                    @(lang == "th"
                        ? "กรุณาจดหมายเลขคำขอไว้สำหรับอ้างอิงในการติดต่อครั้งต่อไป"
                        : "Please keep your request number for future reference.")
                </p>

                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-primary px-4"
                       style="background:var(--needis-primary);border-color:var(--needis-primary)">
                        <i class="bi bi-house me-1"></i>
                        @(lang == "th" ? "กลับหน้าหลัก" : "Back to Home")
                    </a>
                    <a asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-primary px-4"
                       style="color:var(--needis-primary);border-color:var(--needis-primary)">
                        <i class="bi bi-box-seam me-1"></i>
                        @(lang == "th" ? "ดูสินค้า" : "View Products")
                    </a>
                    <a asp-controller="Services" asp-action="Index"
                       class="btn btn-outline-primary px-4"
                       style="color:var(--needis-primary);border-color:var(--needis-primary)">
                        <i class="bi bi-tools me-1"></i>
                        @(lang == "th" ? "ดูบริการ" : "View Services")
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>
