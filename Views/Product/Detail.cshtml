@model ProductDetailViewModel
@using Needis.Web.Models
@{
    var lang = Model.CurrentLanguage;
    string L(string? th, string? en) => lang == "th" ? (th ?? en ?? "") : (en ?? th ?? "");

    var product   = Model.Product;
    var name      = L(product.NameTH, product.NameEN);
    var catName   = L(product.Category?.NameTH, product.Category?.NameEN);
    var shortDesc = L(product.ShortDescriptionTH, product.ShortDescriptionEN);
    var fullDesc  = L(product.FullDescriptionTH,  product.FullDescriptionEN);
    var spec      = L(product.SpecificationTH,    product.SpecificationEN);

    var structuredSpecs    = Model.Specifications;
    var hasStructuredSpecs = structuredSpecs.Any();
    var highlightedSpecs   = structuredSpecs.Where(s => s.IsHighlight).Take(4).ToList();

    // Group by localized group label, preserving order
    var specGroups = structuredSpecs
        .GroupBy(s => lang == "th"
            ? (string.IsNullOrWhiteSpace(s.SpecGroupTH) ? (s.SpecGroupEN ?? "") : s.SpecGroupTH)
            : (string.IsNullOrWhiteSpace(s.SpecGroupEN) ? (s.SpecGroupTH ?? "") : s.SpecGroupEN))
        .ToList();

    ViewData["Title"] = name;
    ViewData["FullWidth"] = true;
}

@* ── Page Header ─────────────────────────────────────────────────────────── *@
<div class="product-page-header">
    <div class="container py-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-white-50">
                        @(lang == "th" ? "หน้าหลัก" : "Home")
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Product" asp-action="Index" class="text-white-50">
                        @(lang == "th" ? "สินค้า" : "Products")
                    </a>
                </li>
                @if (product.Category != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Product" asp-action="Index"
                           asp-route-category="@product.Category.Slug"
                           class="text-white-50">@catName</a>
                    </li>
                }
                <li class="breadcrumb-item active text-white" aria-current="page">@name</li>
            </ol>
        </nav>
    </div>
</div>

@* ── Product Detail Body ──────────────────────────────────────────────────── *@
<div class="container py-5">
    <div class="row g-5">

        @* ── A. Image Column ── *@
        <div class="col-lg-5 reveal">
            <div class="product-detail-image-wrap shadow-sm rounded-3 overflow-hidden">
                @if (!string.IsNullOrEmpty(product.MainImagePath))
                {
                    <img src="@product.MainImagePath" alt="@name" class="product-detail-img" />
                }
                else
                {
                    <div class="product-detail-img-placeholder">
                        <i class="bi bi-box-seam"></i>
                    </div>
                }
            </div>
        </div>

        @* ── B. Info Column ── *@
        <div class="col-lg-7 reveal reveal-delay-1">

            @* Category badge *@
            @if (!string.IsNullOrEmpty(catName))
            {
                <div class="mb-2">
                    <a asp-controller="Product" asp-action="Index"
                       asp-route-category="@product.Category?.Slug"
                       class="badge product-cat-badge text-decoration-none">
                        <i class="bi bi-tag me-1"></i>@catName
                    </a>
                </div>
            }

            <h1 class="fw-bold mb-2" style="font-size:clamp(1.4rem,3vw,2rem);color:#1a2b6b">@name</h1>

            @* Brand / Model / SKU *@
            @if (!string.IsNullOrEmpty(product.Brand) || !string.IsNullOrEmpty(product.Model))
            {
                <p class="text-muted mb-1">
                    @if (!string.IsNullOrEmpty(product.Brand))
                    {
                        <span class="fw-semibold">@product.Brand</span>
                    }
                    @if (!string.IsNullOrEmpty(product.Model))
                    {
                        @: · @product.Model
                    }
                </p>
            }
            @if (!string.IsNullOrEmpty(product.Sku))
            {
                <p class="small text-muted mb-3">
                    @(lang == "th" ? "รหัสสินค้า" : "Part No."):
                    <code class="ms-1">@product.Sku</code>
                </p>
            }

            @* Price *@
            @if (product.IsPriceVisible && product.Price.HasValue)
            {
                <div class="product-detail-price mb-3">
                    @product.Price.Value.ToString("N2") ฿
                </div>
            }
            else
            {
                <div class="mb-3">
                    <span class="badge bg-light text-muted border">
                        @(lang == "th" ? "ติดต่อสอบถามราคา" : "Contact us for pricing")
                    </span>
                </div>
            }

            @* Short description *@
            @if (!string.IsNullOrEmpty(shortDesc))
            {
                <p class="text-muted lh-lg mb-3">@shortDesc</p>
            }

            @* Key Specifications highlight (up to 4 highlighted specs) *@
            @if (highlightedSpecs.Any())
            {
                <div class="row g-2 mb-4">
                    @foreach (var hs in highlightedSpecs)
                    {
                        var hsName  = L(hs.SpecNameTH,  hs.SpecNameEN);
                        var hsValue = L(hs.SpecValueTH, hs.SpecValueEN);
                        var hsUnit  = L(hs.UnitTH,      hs.UnitEN);
                        <div class="col-6 col-sm-3">
                            <div class="rounded-2 p-2 text-center h-100"
                                 style="background:#f0f3ff;border:1px solid #d0d9ff">
                                <div class="small fw-semibold text-muted" style="font-size:.72rem;line-height:1.3">@hsName</div>
                                <div class="fw-bold mt-1" style="color:#2d4199;font-size:.95rem">
                                    @hsValue
                                    @if (!string.IsNullOrEmpty(hsUnit))
                                    {
                                        <span class="fw-normal text-muted small ms-1">@hsUnit</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @* CTA Buttons *@
            <div class="d-flex flex-wrap gap-2 mb-4">
                @if (!string.IsNullOrEmpty(product.Category?.Slug))
                {
                    <a asp-controller="Product" asp-action="Index"
                       asp-route-category="@product.Category.Slug"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>
                        @(lang == "th" ? "กลับไปหมวดหมู่" : "Back to Category")
                    </a>
                }
                @* Add to Quote Cart *@
                <form asp-controller="QuotationCart" asp-action="AddProduct" method="post"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product.Id" />
                    <input type="hidden" name="quantity" value="1" />
                    <input type="hidden" name="returnUrl" value="/Product/Detail/@product.Slug" />
                    <button type="submit" class="btn btn-success px-3">
                        <i class="bi bi-cart-plus me-1"></i>
                        @(lang == "th" ? "เพิ่มในรายการขอราคา" : "Add to Quote")
                    </button>
                </form>
                <a asp-controller="Quotation"
                   asp-action="Create"
                   asp-route-productSlug="@product.Slug"
                   class="btn btn-primary px-4"
                   style="background:#2d4199;border-color:#2d4199">
                    <i class="bi bi-envelope me-1"></i>
                    @(lang == "th" ? "ขอใบเสนอราคา" : "Request Quotation")
                </a>
                @if (!string.IsNullOrEmpty(product.BrochureFilePath))
                {
                    <a href="@product.BrochureFilePath" target="_blank"
                       class="btn btn-outline-danger">
                        <i class="bi bi-file-earmark-pdf me-1"></i>
                        @(lang == "th" ? "ดาวน์โหลดโบรชัวร์" : "Download Brochure")
                    </a>
                }
            </div>
            @* Quote Cart link *@
            <div class="mb-3">
                <a asp-controller="QuotationCart" asp-action="Index"
                   class="small text-decoration-none" style="color:#2d4199">
                    <i class="bi bi-cart3 me-1"></i>
                    @(lang == "th" ? "ดูรายการขอใบเสนอราคา" : "View Quote Cart")
                    <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

        </div>
    </div>

    @* ── C. Full Description + Specification ─────────────────────────────── *@
    @{
        var hasSpec = hasStructuredSpecs || !string.IsNullOrEmpty(spec);
    }
    @if (!string.IsNullOrEmpty(fullDesc) || hasSpec)
    {
        <div class="row g-4 mt-2 reveal">

            @if (!string.IsNullOrEmpty(fullDesc))
            {
                <div class="@(hasSpec ? "col-lg-6" : "col-12")">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                            <h5 class="fw-bold" style="color:#2d4199">
                                <i class="bi bi-file-text me-2"></i>
                                @(lang == "th" ? "รายละเอียดสินค้า" : "Product Description")
                            </h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <div class="product-description">@fullDesc</div>
                        </div>
                    </div>
                </div>
            }

            @if (hasSpec)
            {
                <div class="@(!string.IsNullOrEmpty(fullDesc) ? "col-lg-6" : "col-12")">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-header bg-transparent border-0 pt-3 pb-0 px-4">
                            <h5 class="fw-bold" style="color:#2d4199">
                                <i class="bi bi-list-check me-2"></i>
                                @(lang == "th" ? "ข้อมูลจำเพาะ" : "Specifications")
                            </h5>
                        </div>
                        <div class="card-body px-4 pb-4 pt-2">

                            @if (hasStructuredSpecs)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered align-middle mb-0"
                                           style="font-size:.88rem">
                                        <thead style="background:#f0f3ff">
                                            <tr>
                                                <th class="py-2 ps-3" style="width:35%;color:#2d4199">
                                                    @(lang == "th" ? "รายการ" : "Parameter")
                                                </th>
                                                <th class="py-2" style="color:#2d4199">
                                                    @(lang == "th" ? "ค่า" : "Value")
                                                </th>
                                                <th class="py-2 d-none d-md-table-cell" style="width:25%;color:#2d4199">
                                                    @(lang == "th" ? "หมายเหตุ" : "Remark")
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var grp in specGroups)
                                            {
                                                @if (!string.IsNullOrWhiteSpace(grp.Key))
                                                {
                                                    <tr style="background:#e8ecff">
                                                        <td colspan="3" class="ps-3 py-1 fw-semibold small"
                                                            style="color:#2d4199;letter-spacing:.02em">
                                                            <i class="bi bi-folder2 me-1 opacity-75"></i>@grp.Key
                                                        </td>
                                                    </tr>
                                                }
                                                @foreach (var s in grp)
                                                {
                                                    var sName   = L(s.SpecNameTH,  s.SpecNameEN);
                                                    var sValue  = L(s.SpecValueTH, s.SpecValueEN);
                                                    var sUnit   = L(s.UnitTH,      s.UnitEN);
                                                    var sRemark = L(s.RemarkTH,    s.RemarkEN);
                                                    <tr class="@(s.IsHighlight ? "table-warning fw-semibold" : "")">
                                                        <td class="ps-3 py-2">
                                                            @if (s.IsHighlight)
                                                            {
                                                                <i class="bi bi-star-fill me-1 text-warning" style="font-size:.75rem"></i>
                                                            }
                                                            @sName
                                                        </td>
                                                        <td class="py-2">
                                                            @sValue
                                                            @if (!string.IsNullOrEmpty(sUnit))
                                                            {
                                                                <span class="text-muted ms-1 fw-normal small">@sUnit</span>
                                                            }
                                                        </td>
                                                        <td class="py-2 text-muted small d-none d-md-table-cell">@sRemark</td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <pre class="product-spec">@spec</pre>
                            }

                        </div>
                    </div>
                </div>
            }

        </div>
    }

    @* ── D. Related Products ─────────────────────────────────────────────── *@
    @if (Model.RelatedProducts.Any())
    {
        <div class="mt-5">
            <h4 class="fw-bold mb-4" style="color:#1a2b6b">
                @(lang == "th" ? "สินค้าในหมวดเดียวกัน" : "Related Products")
            </h4>
            <div class="row g-4">
                @foreach (var (rel, relIdx) in Model.RelatedProducts.Select((r, i) => (r, i)))
                {
                    var relName = L(rel.NameTH, rel.NameEN);
                    var relDesc = L(rel.ShortDescriptionTH, rel.ShortDescriptionEN);
                    var relDelay = (relIdx % 4) switch { 1 => "reveal-delay-1", 2 => "reveal-delay-2", 3 => "reveal-delay-3", _ => "" };

                    <div class="col-lg-3 col-md-6 reveal @relDelay">
                        <div class="product-card card shadow-sm h-100">
                            <a asp-controller="Product" asp-action="Detail"
                               asp-route-slug="@rel.Slug"
                               class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(rel.MainImagePath))
                                {
                                    <img src="@rel.MainImagePath" alt="@relName"
                                         class="product-card-img" />
                                }
                                else
                                {
                                    <div class="product-card-img-placeholder">
                                        <i class="bi bi-box-seam"></i>
                                    </div>
                                }
                            </a>
                            <div class="card-body d-flex flex-column">
                                <h6 class="fw-bold text-dark mb-1">
                                    <a asp-controller="Product" asp-action="Detail"
                                       asp-route-slug="@rel.Slug"
                                       class="text-decoration-none text-dark">@relName</a>
                                </h6>
                                @if (!string.IsNullOrEmpty(rel.Brand) || !string.IsNullOrEmpty(rel.Model))
                                {
                                    <p class="small text-muted mb-1">
                                        @rel.Brand@(!string.IsNullOrEmpty(rel.Brand) && !string.IsNullOrEmpty(rel.Model) ? " · " : "")@rel.Model
                                    </p>
                                }
                                @if (!string.IsNullOrEmpty(relDesc))
                                {
                                    <p class="small text-muted mb-0 flex-grow-1">
                                        @(relDesc.Length > 70 ? relDesc[..70] + "…" : relDesc)
                                    </p>
                                }
                                <div class="mt-auto pt-2">
                                    @if (rel.IsPriceVisible && rel.Price.HasValue)
                                    {
                                        <p class="fw-bold mb-0 small" style="color:#2d4199">
                                            @rel.Price.Value.ToString("N2") ฿
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

