@model ProductDetailViewModel
@using Needis.Web.Models
@inject Needis.Web.Services.Content.IRichContentService RichContentSvc
@{
    var lang = Model.CurrentLanguage;
    string L(string? th, string? en) => lang == "th" ? (th ?? en ?? "") : (en ?? th ?? "");

    var product   = Model.Product;
    var name      = L(product.NameTH, product.NameEN);
    var catName   = L(product.Category?.NameTH, product.Category?.NameEN);
    var shortDesc = L(product.ShortDescriptionTH, product.ShortDescriptionEN);
    var fullDesc  = L(product.FullDescriptionTH,  product.FullDescriptionEN);
    var spec      = L(product.SpecificationTH,    product.SpecificationEN);

    var structuredSpecs    = Model.Specifications;
    var hasStructuredSpecs = structuredSpecs.Any();
    var highlightedSpecs   = structuredSpecs.Where(s => s.IsHighlight).Take(4).ToList();

    var specGroups = structuredSpecs
        .GroupBy(s => lang == "th"
            ? (string.IsNullOrWhiteSpace(s.SpecGroupTH) ? (s.SpecGroupEN ?? "") : s.SpecGroupTH)
            : (string.IsNullOrWhiteSpace(s.SpecGroupEN) ? (s.SpecGroupTH ?? "") : s.SpecGroupEN))
        .ToList();

    var hasSpec = hasStructuredSpecs || !string.IsNullOrEmpty(spec);

    ViewData["Title"] = name;
    ViewData["FullWidth"] = true;
}

@* ── Page Header / Breadcrumb ────────────────────────────────────────────── *@
<div class="product-page-header">
    <div class="container py-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-white-50">
                        @(lang == "th" ? "หน้าหลัก" : "Home")
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Product" asp-action="Index" class="text-white-50">
                        @(lang == "th" ? "สินค้า" : "Products")
                    </a>
                </li>
                @if (product.Category != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Product" asp-action="Index"
                           asp-route-category="@product.Category.Slug"
                           class="text-white-50">@catName</a>
                    </li>
                }
                <li class="breadcrumb-item active text-white" aria-current="page">@name</li>
            </ol>
        </nav>
    </div>
</div>

@* ── A. Product Hero ──────────────────────────────────────────────────────── *@
<div class="product-hero-section">
    <div class="container">
        <div class="row g-4 g-lg-5 align-items-start">

            @* ── Image Column ── *@
            <div class="col-lg-5 reveal">
                <div class="product-media-card">
                    @if (!string.IsNullOrEmpty(product.MainImagePath))
                    {
                        <img src="@product.MainImagePath" alt="@Html.Encode(name)"
                             class="product-media-img" />
                    }
                    else
                    {
                        <div class="product-media-placeholder">
                            <i class="bi bi-box-seam"></i>
                        </div>
                    }
                </div>
            </div>

            @* ── Info Column ── *@
            <div class="col-lg-7 reveal reveal-delay-1">
                <div class="product-summary-card">

                    @* Category chip *@
                    @if (!string.IsNullOrEmpty(catName))
                    {
                        <div class="mb-3">
                            <a asp-controller="Product" asp-action="Index"
                               asp-route-category="@product.Category?.Slug"
                               class="product-cat-chip text-decoration-none">
                                <i class="bi bi-tag-fill me-1"></i>@catName
                            </a>
                        </div>
                    }

                    @* Product name *@
                    <h1 class="product-detail-title">@name</h1>

                    @* Brand / Model / SKU meta row *@
                    @if (!string.IsNullOrEmpty(product.Brand) || !string.IsNullOrEmpty(product.Model) || !string.IsNullOrEmpty(product.Sku))
                    {
                        <div class="product-meta-row">
                            @if (!string.IsNullOrEmpty(product.Brand))
                            {
                                <span class="product-meta-chip">
                                    <i class="bi bi-building me-1 opacity-75"></i>@product.Brand
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(product.Model))
                            {
                                <span class="product-meta-chip">
                                    <i class="bi bi-cpu me-1 opacity-75"></i>@product.Model
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(product.Sku))
                            {
                                <span class="product-meta-chip product-meta-sku">
                                    <i class="bi bi-upc me-1 opacity-75"></i>@product.Sku
                                </span>
                            }
                        </div>
                    }

                    @* Hot Product / Promotion badges *@
                    @if (product.IsFeatured || product.IsPromotion)
                    {
                        var promoLabel = lang == "th"
                            ? (!string.IsNullOrWhiteSpace(product.PromotionLabelTH) ? product.PromotionLabelTH : "โปรโมชั่น")
                            : (!string.IsNullOrWhiteSpace(product.PromotionLabelEN) ? product.PromotionLabelEN : "Promotion");
                        var hotLabel = lang == "th" ? "สินค้าแนะนำ" : "Hot Product";
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @if (product.IsPromotion)
                            {
                                <span class="product-badge product-badge-promotion">@promoLabel</span>
                            }
                            @if (product.IsFeatured)
                            {
                                <span class="product-badge product-badge-hot">@hotLabel</span>
                            }
                        </div>
                    }

                    @* Price *@
                    <div class="product-price-block">
                        @if (product.IsPriceVisible && product.Price.HasValue)
                        {
                            <span class="product-price-value">@product.Price.Value.ToString("N2")</span>
                            <span class="product-price-currency">฿</span>
                        }
                        else
                        {
                            <span class="product-price-contact">
                                <i class="bi bi-headset me-1"></i>
                                @(lang == "th" ? "ติดต่อสอบถามราคา" : "Contact us for pricing")
                            </span>
                        }
                    </div>

                    @* Short description *@
                    @if (!string.IsNullOrEmpty(shortDesc))
                    {
                        <div class="product-short-desc rich-content">@Html.Raw(RichContentSvc.ToSafeHtml(shortDesc))</div>
                    }

                    @* Key Spec highlights *@
                    @if (highlightedSpecs.Any())
                    {
                        <div class="row g-2 mb-4">
                            @foreach (var hs in highlightedSpecs)
                            {
                                var hsName  = L(hs.SpecNameTH,  hs.SpecNameEN);
                                var hsValue = L(hs.SpecValueTH, hs.SpecValueEN);
                                var hsUnit  = L(hs.UnitTH,      hs.UnitEN);
                                <div class="col-6 col-sm-3">
                                    <div class="product-spec-chip">
                                        <div class="product-spec-chip-label">@hsName</div>
                                        <div class="product-spec-chip-value">
                                            @hsValue
                                            @if (!string.IsNullOrEmpty(hsUnit))
                                            {
                                                <span class="product-spec-chip-unit">@hsUnit</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @* ── CTA Actions ── *@
                    <div class="product-actions">

                        @* Primary row: Add to Quote + Request Quotation *@
                        <div class="product-actions-primary">
                            <form asp-controller="QuotationCart" asp-action="AddProduct" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <input type="hidden" name="returnUrl" value="/Product/Detail/@product.Slug" />
                                <button type="submit" class="btn btn-pd btn-pd-quote">
                                    <i class="bi bi-cart-plus me-2"></i>
                                    @Model.T("product.add_to_quote", lang == "th" ? "เพิ่มในรายการขอราคา" : "Add to Quote")
                                </button>
                            </form>

                            <a asp-controller="Quotation"
                               asp-action="Create"
                               asp-route-productSlug="@product.Slug"
                               class="btn btn-pd btn-pd-primary">
                                <i class="bi bi-envelope me-2"></i>
                                @(lang == "th" ? "ขอใบเสนอราคา" : "Request Quotation")
                            </a>
                        </div>

                        @* Secondary row: Back to Category + Brochure *@
                        <div class="product-actions-secondary">
                            @if (!string.IsNullOrEmpty(product.Category?.Slug))
                            {
                                <a asp-controller="Product" asp-action="Index"
                                   asp-route-category="@product.Category.Slug"
                                   class="btn btn-pd btn-pd-back">
                                    <i class="bi bi-arrow-left me-1"></i>
                                    @(lang == "th" ? "กลับไปหมวดหมู่" : "Back to Category")
                                </a>
                            }

                            @if (!string.IsNullOrEmpty(product.BrochureFilePath))
                            {
                                <a href="@product.BrochureFilePath" target="_blank"
                                   class="btn btn-pd btn-pd-brochure">
                                    <i class="bi bi-file-earmark-pdf me-1"></i>
                                    @(lang == "th" ? "ดาวน์โหลดโบรชัวร์" : "Brochure")
                                </a>
                            }
                        </div>

                    </div>

                    @* View Quote Cart subtle link *@
                    <div class="product-cart-link">
                        <a asp-controller="QuotationCart" asp-action="Index"
                           class="product-cart-link-anchor">
                            <i class="bi bi-cart3 me-1"></i>
                            @(lang == "th" ? "ดูรายการขอใบเสนอราคา" : "View Quote Cart")
                            <i class="bi bi-chevron-right ms-1 small"></i>
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@* ── B. Product Video ─────────────────────────────────────────────────────── *@
@if (FF.ProductYoutubeVideoEnabled && Model.YoutubeEmbedUrl is not null)
{
    var videoTitle = L(product.YoutubeVideoTitleTH, product.YoutubeVideoTitleEN);
    var videoDesc  = L(product.YoutubeVideoDescriptionTH, product.YoutubeVideoDescriptionEN);
    var sectionTitle = !string.IsNullOrEmpty(videoTitle)
        ? videoTitle
        : (lang == "th" ? "วิดีโอสินค้า" : "Product Video");
    var iframeTitle = !string.IsNullOrEmpty(videoTitle) ? videoTitle : name;

    <div class="product-content-section">
        <div class="container">
            <div class="product-section-heading reveal">
                <div class="product-section-icon-wrap video-icon">
                    <i class="bi bi-play-circle-fill"></i>
                </div>
                <div>
                    <h2 class="product-section-title">@sectionTitle</h2>
                    @if (!string.IsNullOrEmpty(videoDesc))
                    {
                        <p class="product-section-subtitle">@videoDesc</p>
                    }
                </div>
            </div>
            <div class="product-video-frame reveal">
                <iframe src="@Model.YoutubeEmbedUrl"
                        title="@Html.Encode(iframeTitle)"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        loading="lazy"
                        referrerpolicy="strict-origin-when-cross-origin"></iframe>
            </div>
        </div>
    </div>
}

@* ── C. Description + Specifications ─────────────────────────────────────── *@
@if (!string.IsNullOrEmpty(fullDesc) || hasSpec)
{
    <div class="product-content-section product-content-section--alt">
        <div class="container">
            <div class="row g-4">

                @if (!string.IsNullOrEmpty(fullDesc))
                {
                    <div class="@(hasSpec ? "col-lg-6" : "col-12") reveal">
                        <div class="product-content-card">
                            <div class="product-content-card-header">
                                <div class="product-section-icon-wrap">
                                    <i class="bi bi-file-text-fill"></i>
                                </div>
                                <h3 class="product-content-card-title">
                                    @(lang == "th" ? "รายละเอียดสินค้า" : "Product Description")
                                </h3>
                            </div>
                            <div class="product-content-card-body">
                                <div class="product-description rich-content">@Html.Raw(RichContentSvc.ToSafeHtml(fullDesc))</div>
                            </div>
                        </div>
                    </div>
                }

                @if (hasSpec)
                {
                    <div class="@(!string.IsNullOrEmpty(fullDesc) ? "col-lg-6" : "col-12") reveal @(!string.IsNullOrEmpty(fullDesc) ? "reveal-delay-1" : "")">
                        <div class="product-content-card">
                            <div class="product-content-card-header">
                                <div class="product-section-icon-wrap">
                                    <i class="bi bi-list-check"></i>
                                </div>
                                <h3 class="product-content-card-title">
                                    @(lang == "th" ? "ข้อมูลจำเพาะ" : "Specifications")
                                </h3>
                            </div>
                            <div class="product-content-card-body pt-0">
                                @if (hasStructuredSpecs)
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered align-middle mb-0"
                                               style="font-size:.88rem">
                                            <thead style="background:#f0f3ff">
                                                <tr>
                                                    <th class="py-2 ps-3" style="width:35%;color:var(--needis-primary)">
                                                        @(lang == "th" ? "รายการ" : "Parameter")
                                                    </th>
                                                    <th class="py-2" style="color:var(--needis-primary)">
                                                        @(lang == "th" ? "ค่า" : "Value")
                                                    </th>
                                                    <th class="py-2 d-none d-md-table-cell" style="width:25%;color:var(--needis-primary)">
                                                        @(lang == "th" ? "หมายเหตุ" : "Remark")
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var grp in specGroups)
                                                {
                                                    @if (!string.IsNullOrWhiteSpace(grp.Key))
                                                    {
                                                        <tr style="background:#e8ecff">
                                                            <td colspan="3" class="ps-3 py-1 fw-semibold small"
                                                                style="color:var(--needis-primary);letter-spacing:.02em">
                                                                <i class="bi bi-folder2 me-1 opacity-75"></i>@grp.Key
                                                            </td>
                                                        </tr>
                                                    }
                                                    @foreach (var s in grp)
                                                    {
                                                        var sName   = L(s.SpecNameTH,  s.SpecNameEN);
                                                        var sValue  = L(s.SpecValueTH, s.SpecValueEN);
                                                        var sUnit   = L(s.UnitTH,      s.UnitEN);
                                                        var sRemark = L(s.RemarkTH,    s.RemarkEN);
                                                        <tr class="@(s.IsHighlight ? "table-warning fw-semibold" : "")">
                                                            <td class="ps-3 py-2">
                                                                @if (s.IsHighlight)
                                                                {
                                                                    <i class="bi bi-star-fill me-1 text-warning" style="font-size:.75rem"></i>
                                                                }
                                                                @sName
                                                            </td>
                                                            <td class="py-2">
                                                                @sValue
                                                                @if (!string.IsNullOrEmpty(sUnit))
                                                                {
                                                                    <span class="text-muted ms-1 fw-normal small">@sUnit</span>
                                                                }
                                                            </td>
                                                            <td class="py-2 text-muted small d-none d-md-table-cell">@sRemark</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="product-spec rich-content">@Html.Raw(RichContentSvc.ToSafeHtml(spec))</div>
                                }
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
}

@* ── D. Related Products ──────────────────────────────────────────────────── *@
@if (Model.RelatedProducts.Any())
{
    <div class="product-content-section">
        <div class="container">
            <div class="product-section-heading reveal">
                <div class="product-section-icon-wrap">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </div>
                <div>
                    <h2 class="product-section-title">
                        @(lang == "th" ? "สินค้าในหมวดเดียวกัน" : "Related Products")
                    </h2>
                </div>
            </div>
            <div class="row g-4">
                @foreach (var (rel, relIdx) in Model.RelatedProducts.Select((r, i) => (r, i)))
                {
                    var relName  = L(rel.NameTH, rel.NameEN);
                    var relDescRaw = L(rel.ShortDescriptionTH, rel.ShortDescriptionEN);
                    var relDescFallbackRaw = L(rel.FullDescriptionTH, rel.FullDescriptionEN);
                    var relDesc  = !string.IsNullOrWhiteSpace(relDescRaw)
                        ? RichContentSvc.ToPlainText(relDescRaw, 70)
                        : RichContentSvc.ToPlainText(relDescFallbackRaw, 70);
                    var relDelay = (relIdx % 4) switch { 1 => "reveal-delay-1", 2 => "reveal-delay-2", 3 => "reveal-delay-3", _ => "" };

                    <div class="col-lg-3 col-md-6 reveal @relDelay">
                        <div class="product-card card shadow-sm h-100">
                            <partial name="_ProductBadges" model="(rel, lang)" />
                            <a asp-controller="Product" asp-action="Detail"
                               asp-route-slug="@rel.Slug"
                               class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(rel.MainImagePath))
                                {
                                    <img src="@rel.MainImagePath" alt="@relName"
                                         class="product-card-img" />
                                }
                                else
                                {
                                    <div class="product-card-img-placeholder">
                                        <i class="bi bi-box-seam"></i>
                                    </div>
                                }
                            </a>
                            <div class="card-body d-flex flex-column">
                                <h6 class="fw-bold text-dark mb-1">
                                    <a asp-controller="Product" asp-action="Detail"
                                       asp-route-slug="@rel.Slug"
                                       class="text-decoration-none text-dark">@relName</a>
                                </h6>
                                @if (!string.IsNullOrEmpty(rel.Brand) || !string.IsNullOrEmpty(rel.Model))
                                {
                                    <p class="small text-muted mb-1">
                                        @rel.Brand@(!string.IsNullOrEmpty(rel.Brand) && !string.IsNullOrEmpty(rel.Model) ? " · " : "")@rel.Model
                                    </p>
                                }
                                @if (!string.IsNullOrEmpty(relDesc))
                                {
                                    <p class="small text-muted mb-0 flex-grow-1">
                                        @relDesc
                                    </p>
                                }
                                <div class="mt-auto pt-2">
                                    @if (rel.IsPriceVisible && rel.Price.HasValue)
                                    {
                                        <p class="fw-bold mb-0 small" style="color:var(--needis-primary)">
                                            @rel.Price.Value.ToString("N2") ฿
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
